---
import LanguageSelect from '@/components/layout/LanguageSelect.astro';
import { getWhyHireMeContent } from '@/data/why-hire-me';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import { getRecruiterProfilePath } from '@/i18n/routing';
import logo from '@assets/logo.png';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const currentPath = Astro.url.pathname;
const whyHireMeContent = getWhyHireMeContent(locale);
const labels = whyHireMeContent.navbar;

const homePath = `/${locale}`;
const recruiterPath = getRecruiterProfilePath(locale);
const sectionBasePath = currentPath === recruiterPath ? recruiterPath : homePath;
const experiencePath = `${sectionBasePath}#experience`;
const certificationsPath = `${sectionBasePath}#certifications`;
const navLabelById = Object.fromEntries(
    labels.items.map((item) => [item.id, item.label]),
) as Record<'posts' | 'experience' | 'certifications', string>;
const navHrefById = {
    posts: whyHireMeContent.navbar.postsHref,
    experience: experiencePath,
    certifications: certificationsPath,
};
const isRecruiterProfileRoute = currentPath === recruiterPath;
---

<header
    data-navbar-root
    class:list={[
        'py-8 font-medium border-b',
        isRecruiterProfileRoute
            ? 'border-white/10 text-white'
            : 'border-slate-200 text-slate-900',
    ]}
>
    <div class="flex items-center justify-between gap-4">
        <a
            class="inline-flex items-center"
            href={homePath}
        >
            <img
                src={logo.src}
                alt="Nicolás Montiel"
                class="h-12 w-auto"
                width={logo.width}
                height={logo.height}
            />
        </a>

        <nav class="hidden md:flex gap-4 items-center text-sm">
            {
                labels.items.map((item, index) => (
                    <>
                        <a
                            class:list={[
                                'transition-colors',
                                isRecruiterProfileRoute
                                    ? 'hover:text-primary-300'
                                    : 'hover:text-indigo-600',
                            ]}
                            target={item.id === 'posts' ? '_blank' : undefined}
                            href={navHrefById[item.id]}
                        >
                            {item.label}
                        </a>
                        {index < labels.items.length - 1 && (
                            <span class={isRecruiterProfileRoute ? 'text-white/20' : 'text-slate-300'}> / </span>
                        )}
                    </>
                ))
            }
            <span class={isRecruiterProfileRoute ? 'text-white/20' : 'text-slate-300'}> / </span>
            <LanguageSelect
                id="desktop-language-select"
                selectClass={[
                    'rounded-md border bg-transparent px-2 py-1 focus:outline-none focus:ring-2',
                    isRecruiterProfileRoute
                        ? 'border-white/12 text-white focus:ring-primary/40'
                        : 'border-slate-200 text-slate-900 focus:ring-indigo-200',
                ].join(' ')}
            />
        </nav>

        <button
            class:list={[
                'md:hidden inline-flex h-10 w-10 items-center justify-center rounded-md border',
                isRecruiterProfileRoute
                    ? 'border-white/12 text-white/80 hover:text-primary-300'
                    : 'border-slate-200 text-slate-700 hover:text-indigo-600',
            ]}
            type="button"
            data-menu-toggle
            aria-label="Toggle navigation menu"
            aria-expanded="false"
        >
            <span class="sr-only">Open menu</span>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 7h16M4 12h16M4 17h16"
                ></path>
            </svg>
        </button>
    </div>

    <nav
        class:list={[
            'md:hidden overflow-hidden max-h-0 -translate-y-2 rounded-lg border border-transparent px-0 py-0 opacity-0 pointer-events-none transition-all duration-300 ease-out backdrop-blur',
            isRecruiterProfileRoute ? 'bg-background-primary/95' : 'bg-white/90',
        ]}
        data-mobile-menu
    >
        <div class="flex flex-col gap-4 text-sm">
            <a
                class:list={[
                    'transition-colors',
                    isRecruiterProfileRoute
                        ? 'hover:text-primary-300'
                        : 'hover:text-indigo-600',
                ]}
                data-mobile-link
                href={navHrefById.posts}
                target="_blank"
            >
                {navLabelById.posts}
            </a>
            <a
                class:list={[
                    'transition-colors',
                    isRecruiterProfileRoute
                        ? 'hover:text-primary-300'
                        : 'hover:text-indigo-600',
                ]}
                data-mobile-link
                href={navHrefById.certifications}
            >
                {navLabelById.certifications}
            </a>
            <a
                class:list={[
                    'transition-colors',
                    isRecruiterProfileRoute
                        ? 'hover:text-primary-300'
                        : 'hover:text-indigo-600',
                ]}
                data-mobile-link
                href={navHrefById.experience}
            >
                {navLabelById.experience}
            </a>
            <div>
                <LanguageSelect
                    id="mobile-language-select"
                    labelClass={[
                        'mb-1 block text-xs',
                        isRecruiterProfileRoute ? 'text-white/60' : 'text-slate-500',
                    ].join(' ')}
                    selectClass={[
                        'w-full rounded-md border bg-transparent px-3 py-2 focus:outline-none focus:ring-2',
                        isRecruiterProfileRoute
                            ? 'border-white/12 text-white focus:ring-primary/40'
                            : 'border-slate-200 text-slate-900 focus:ring-indigo-200',
                    ].join(' ')}
                />
            </div>
        </div>
    </nav>
</header>

<script is:inline>
    const navbar = document.querySelector('[data-navbar-root]');

    if (navbar) {
        const isRecruiterProfileRoute = window.location.pathname.endsWith('/why-hire-me')
            || window.location.pathname.endsWith('/porque-contratarme');
        const toggleButton = navbar.querySelector('[data-menu-toggle]');
        const mobileMenu = navbar.querySelector('[data-mobile-menu]');
        const mobileLinks = navbar.querySelectorAll('[data-mobile-link]');
        const closedClasses = [
            'max-h-0',
            'opacity-0',
            '-translate-y-2',
            'pointer-events-none',
            'border-transparent',
            'px-0',
            'py-0',
        ];
        const openClasses = [
            'max-h-96',
            'opacity-100',
            'translate-y-0',
            'mt-4',
            isRecruiterProfileRoute ? 'border-white/10' : 'border-slate-200',
            'p-4',
        ];

        const closeMenu = () => {
            if (!mobileMenu) return;
            mobileMenu.classList.add(...closedClasses);
            mobileMenu.classList.remove(...openClasses);
            if (toggleButton)
                toggleButton.setAttribute('aria-expanded', 'false');
        };

        if (toggleButton && mobileMenu) {
            toggleButton.addEventListener('click', () => {
                const isClosed = mobileMenu.classList.contains('max-h-0');

                if (isClosed) {
                    mobileMenu.classList.remove(...closedClasses);
                    mobileMenu.classList.add(...openClasses);
                    toggleButton.setAttribute('aria-expanded', 'true');
                    return;
                }

                closeMenu();
            });
        }

        mobileLinks.forEach((link) => {
            link.addEventListener('click', closeMenu);
        });

    }
</script>
