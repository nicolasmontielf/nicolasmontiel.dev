---
import devIcon from '@assets/icons/devto.svg';
import linkedinIcon from '@assets/icons/linkedin.svg';
import githubIcon from '@assets/icons/github.svg';
import mailIcon from '@assets/icons/mail.svg';
import PresentationBodyEs from '@components/home/PresentationBody.es.astro';
import PresentationBodyEn from '@components/home/PresentationBody.en.astro';
import type { Locale } from '@/i18n/locales';

type Props = {
	locale: Locale;
	greeting: string;
};

const { locale, greeting } = Astro.props as Props;

const socialMediaItems = [
    {
        url: 'https://www.linkedin.com/in/nicolasmontielf/?locale=en_US',
        icon: linkedinIcon,
    },
    {
        url: 'https://github.com/nicolasmontielf',
        icon: githubIcon,
    },
    {
        url: 'https://dev.to/nicolasmontielf',
        icon: devIcon,
    },
    {
        url: 'mailto:nicolasmontielf@gmail.com',
        icon: mailIcon,
    }
];
---

<section class="grid items-center gap-12 md:grid-cols-2">
	<div class="w-full flex flex-col gap-6">
		<h3 class="text-6xl text-slate-900 font-bold tracking-tight">{greeting}</h3>

		<div class="text-lg leading-relaxed text-slate-700">
			{locale === 'es' ? <PresentationBodyEs /> : <PresentationBodyEn />}
		</div>

		<div class="flex gap-4 items-center">
			{
				socialMediaItems.map((item) => {
					return (
						<a href={item.url} target="_blank" class="group" rel="noreferrer">
							<div
								class="w-5 h-5 bg-slate-400 group-hover:bg-indigo-600 transition-colors cursor-pointer"
								style={`
                                    mask-image: url(${item.icon.src}); 
                                    -webkit-mask-image: url(${item.icon.src});
                                    mask-size: contain; 
                                    -webkit-mask-size: contain;
                                    mask-repeat: no-repeat;
                                    -webkit-mask-repeat: no-repeat;
                                    mask-position: center;
                                    -webkit-mask-position: center;
                                `}
							/>
						</a>
					);
				})
			}
		</div>
	</div>

	<div class="w-full md:justify-self-end">
		<div class="relative mx-auto w-full max-w-md aspect-square">
			<div class="absolute inset-8 rounded-[2rem] bg-gradient-to-br from-indigo-500/30 via-blue-300/40 to-violet-500/30 blur-2xl"></div>
			<div class="absolute inset-10 rounded-3xl border border-indigo-200/60 bg-white/55 backdrop-blur"></div>
			<div class="absolute left-8 top-14 h-24 w-24 rounded-2xl bg-indigo-500/45 shadow-xl"></div>
			<div class="absolute right-12 top-10 h-28 w-28 rounded-2xl bg-blue-400/35 shadow-xl"></div>
			<div class="absolute left-[42%] top-[38%] h-28 w-28 -translate-x-1/2 -translate-y-1/2 rounded-2xl bg-white/80 shadow-2xl"></div>
			<div class="absolute right-16 bottom-16 h-20 w-20 rounded-2xl bg-violet-500/35 shadow-xl"></div>
			<div class="absolute left-14 bottom-10 h-8 w-8 rounded-full bg-sky-200/90"></div>
			<div class="absolute right-10 top-[42%] h-12 w-12 rounded-full bg-indigo-300/75"></div>
		</div>
	</div>
</section>
