---
import devIcon from '@assets/icons/devto.svg';
import linkedinIcon from '@assets/icons/linkedin.svg';
import githubIcon from '@assets/icons/github.svg';
import mailIcon from '@assets/icons/mail.svg';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import PresentationBodyProEn from '@components/home/PresentationBodyPro.en.astro';
import PresentationBodyFreelancerEn from '@components/home/PresentationBodyFreelancer.en.astro';
import PresentationBodyProEs from '@components/home/PresentationBodyPro.es.astro';
import PresentationBodyFreelancerEs from '@components/home/PresentationBodyFreelancer.es.astro';
import type { PresentationProps } from '@/types/home';

const { variant, greeting } = Astro.props as PresentationProps;
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;

const isSpanish = locale === 'es';
const isFreelancer = variant === 'freelancer';

const socialMediaItems = [
    {
        url: 'https://www.linkedin.com/in/nicolasmontielf/?locale=en_US',
        icon: linkedinIcon,
        label: 'LinkedIn',
    },
    {
        url: 'https://github.com/nicolasmontielf',
        icon: githubIcon,
        label: 'GitHub',
    },
    {
        url: 'https://dev.to/nicolasmontielf',
        icon: devIcon,
        label: 'DEV Community',
    },
    {
        url: 'mailto:nicolasmontielf@gmail.com',
        icon: mailIcon,
        label: locale === 'es' ? 'Enviar email' : 'Send email',
    },
];
---

<section class="flex items-center gap-12 w-full md:w-10/12 text-justify">
    <div class="w-full flex flex-col gap-6">
        <h1
            class="text-5xl md:text-6xl text-slate-900 font-bold tracking-tight"
        >
            {greeting}
        </h1>

        <div class="text-lg leading-relaxed text-slate-700">
            {
                isSpanish ? (
                    isFreelancer ? (
                        <PresentationBodyFreelancerEs />
                    ) : (
                        <PresentationBodyProEs />
                    )
                ) : isFreelancer ? (
                    <PresentationBodyFreelancerEn />
                ) : (
                    <PresentationBodyProEn />
                )
            }
        </div>

        <div class="flex gap-4 items-center">
            {
                socialMediaItems.map((item) => {
                    return (
                        <a
                            href={item.url}
                            target="_blank"
                            class="group"
                            rel="noreferrer"
                            aria-label={item.label}
                        >
                            <div
                                class="w-5 h-5 bg-indigo-600 group-hover:bg-indigo-700 transition-colors cursor-pointer"
                                style={`
                                    mask-image: url(${item.icon.src}); 
                                    -webkit-mask-image: url(${item.icon.src});
                                    mask-size: contain; 
                                    -webkit-mask-size: contain;
                                    mask-repeat: no-repeat;
                                    -webkit-mask-repeat: no-repeat;
                                    mask-position: center;
                                    -webkit-mask-position: center;
                                `}
                            />
                        </a>
                    );
                })
            }
        </div>
    </div>

