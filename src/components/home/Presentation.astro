---
import { getWhyHireMeContent } from '@/data/why-hire-me';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import { getSiteCopy } from '@/i18n/site-copy';
import { renderMarkdown } from '@/utils/markdown';
import { Icon } from 'astro-icon/components';
import { Mail } from '@lucide/astro';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const whyHireMeContent = getWhyHireMeContent(locale);
const siteCopy = getSiteCopy(locale);
const bodyParagraphs: string[] = await Promise.all(
    whyHireMeContent.presentation.body.map((paragraph) => renderMarkdown(paragraph)),
);
const greeting = whyHireMeContent.presentation.greeting;

const socialMediaItems = [
    {
        url: 'https://www.linkedin.com/in/nicolasmontielf/?locale=en_US',
        icon: 'simple-icons:linkedin',
        label: siteCopy.common.linkedin,
    },
    {
        url: 'https://github.com/nicolasmontielf',
        icon: 'simple-icons:github',
        label: 'GitHub',
    },
    {
        url: 'https://dev.to/nicolasmontielf',
        icon: 'simple-icons:devdotto',
        label: 'DEV Community',
    },
    {
        url: 'mailto:nicolasmontielf@gmail.com',
        icon: 'mail',
        label: siteCopy.common.email,
    },
];
---

<section class="flex items-center gap-12 w-full md:w-10/12 text-justify">
    <div class="w-full flex flex-col gap-6">
        <h1
            class="text-5xl md:text-6xl text-white font-bold tracking-tight"
        >
            {greeting}
        </h1>

        <div class="space-y-3 text-lg leading-relaxed text-white/72">
            {
                bodyParagraphs.map((paragraph: string) => (
                    <div
                        class="[&>p]:m-0 [&_strong]:font-semibold [&_strong]:text-white"
                        set:html={paragraph}
                    />
                ))
            }
        </div>

        <div class="flex gap-4 items-center">
            {
                socialMediaItems.map((item) => {
                    return (
                        <a
                            href={item.url}
                            target="_blank"
                            class="group"
                            rel="noreferrer"
                            aria-label={item.label}
                        >
                            {item.icon === 'mail' ? (
                                <Mail
                                    class="h-5 w-5 cursor-pointer text-white/85 transition-colors group-hover:text-primary"
                                    stroke-width={2}
                                    aria-hidden="true"
                                />
                            ) : (
                                <Icon
                                    name={item.icon}
                                    class="h-5 w-5 cursor-pointer text-white/85 transition-colors group-hover:text-primary"
                                    aria-hidden="true"
                                />
                            )}
                        </a>
                    );
                })
            }
        </div>
    </div>

