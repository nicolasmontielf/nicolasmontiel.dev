---
import devIcon from '@assets/icons/devto.svg';
import linkedinIcon from '@assets/icons/linkedin.svg';
import githubIcon from '@assets/icons/github.svg';
import mailIcon from '@assets/icons/mail.svg';
import { getWhyHireMeContent } from '@/data/why-hire-me';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import { renderMarkdown } from '@/utils/markdown';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const whyHireMeContent = getWhyHireMeContent(locale);
const bodyParagraphs = await Promise.all(
    whyHireMeContent.presentation.body.map((paragraph) => renderMarkdown(paragraph)),
);
const greeting = whyHireMeContent.presentation.greeting;

const socialMediaItems = [
    {
        url: 'https://www.linkedin.com/in/nicolasmontielf/?locale=en_US',
        icon: linkedinIcon,
        label: 'LinkedIn',
    },
    {
        url: 'https://github.com/nicolasmontielf',
        icon: githubIcon,
        label: 'GitHub',
    },
    {
        url: 'https://dev.to/nicolasmontielf',
        icon: devIcon,
        label: 'DEV Community',
    },
    {
        url: 'mailto:nicolasmontielf@gmail.com',
        icon: mailIcon,
        label: locale === 'es' ? 'Enviar email' : 'Send email',
    },
];
---

<section class="flex items-center gap-12 w-full md:w-10/12 text-justify">
    <div class="w-full flex flex-col gap-6">
        <h1
            class="text-5xl md:text-6xl text-slate-900 font-bold tracking-tight"
        >
            {greeting}
        </h1>

        <div class="space-y-3 text-lg leading-relaxed text-slate-700">
            {
                bodyParagraphs.map((paragraph) => (
                    <div
                        class="[&>p]:m-0 [&_strong]:font-semibold [&_strong]:text-slate-900"
                        set:html={paragraph}
                    />
                ))
            }
        </div>

        <div class="flex gap-4 items-center">
            {
                socialMediaItems.map((item) => {
                    return (
                        <a
                            href={item.url}
                            target="_blank"
                            class="group"
                            rel="noreferrer"
                            aria-label={item.label}
                        >
                            <div
                                class="h-5 w-5 cursor-pointer bg-indigo-600 transition-colors group-hover:bg-indigo-700"
                                style={`
                                    mask-image: url(${item.icon.src}); 
                                    -webkit-mask-image: url(${item.icon.src});
                                    mask-size: contain; 
                                    -webkit-mask-size: contain;
                                    mask-repeat: no-repeat;
                                    -webkit-mask-repeat: no-repeat;
                                    mask-position: center;
                                    -webkit-mask-position: center;
                                `}
                            />
                        </a>
                    );
                })
            }
        </div>
    </div>

