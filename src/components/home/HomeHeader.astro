---
import logo from '@assets/logo.png';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import { getSiteCopy } from '@/i18n/site-copy';
import { getLocalizedPath } from '@/seo/site';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const siteCopy = getSiteCopy(locale);
const currentPath = Astro.url.pathname;
const switchToEsPath = getLocalizedPath(currentPath, 'es');
const switchToEnPath = getLocalizedPath(currentPath, 'en');
---

<header class="mx-auto flex w-full max-w-[1380px] items-center justify-between gap-4 px-1 py-2">
    <a
        class="inline-flex items-center"
        href={`/${locale}`}
    >
        <img
            src={logo.src}
            alt="Nicolás Montiel"
            class="h-10 w-auto sm:h-11"
            width={logo.width}
            height={logo.height}
        />
    </a>

    <div class="flex items-center gap-3">
        <label
            class="sr-only"
            for="home-language-select"
            >{siteCopy.common.languageLabel}</label
        >
        <select
            id="home-language-select"
            data-language-select
            class="bg-transparent text-white border border-white/15 rounded-md px-2 py-1 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-primary/30"
        >
            <option
                value={`/api/set-language?lang=es&redirect=${encodeURIComponent(switchToEsPath)}`}
                selected={locale === 'es'}
                class="text-slate-900"
            >
                ES
            </option>
            <option
                value={`/api/set-language?lang=en&redirect=${encodeURIComponent(switchToEnPath)}`}
                selected={locale === 'en'}
                class="text-slate-900"
            >
                EN
            </option>
        </select>
    </div>
</header>

<script is:inline>
    const languageSelect = document.querySelector('[data-language-select]');

    if (languageSelect) {
        languageSelect.addEventListener('change', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLSelectElement)) return;
            if (target.value) window.location.href = target.value;
        });
    }
</script>
