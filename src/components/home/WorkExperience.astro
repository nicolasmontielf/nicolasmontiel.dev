---
import { getCompanyImageById } from '@/data/companies-icons';
import { getWhyHireMeContent } from '@/data/why-hire-me';
import { getTechBadges } from '@/data/tech-icons';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import { renderMarkdown } from '@/utils/markdown';
import { Icon } from 'astro-icon/components';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const experience = getWhyHireMeContent(locale).experience;
const stackLabel = locale === 'es' ? 'Tecnologias' : 'Stack';
const renderedItems = await Promise.all(
    experience.items.map(async (item) => ({
        ...item,
        companyImage: getCompanyImageById(item.id),
        techBadges: getTechBadges(item.stack),
        renderedSummary: await renderMarkdown(item.summary),
        renderedResponsibilities: await Promise.all(
            item.responsibilities.map((bullet) => renderMarkdown(bullet)),
        ),
    })),
);
---

<section
    id="experience-section"
    class="mt-24"
>
    <div class="max-w-3xl">
        <h2 class="text-4xl font-bold tracking-tight text-indigo-700">
            {experience.title}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600">
            {experience.description}
        </p>
    </div>

    <div class="mt-10 flex flex-col gap-10 md:flex-row md:items-start">
        <aside class="md:w-3/12">
            <div class="space-y-1">
                {
                    renderedItems.map((item, index) => (
                        <button
                            type="button"
                            class:list={[
                                'w-full rounded-r-2xl border-l-2 px-4 py-5 text-left transition-colors',
                                index === 0
                                    ? 'border-indigo-600 bg-indigo-50/70 text-indigo-950'
                                    : 'border-slate-200 text-slate-500 hover:border-indigo-300 hover:bg-indigo-50/40 hover:text-indigo-900',
                            ]}
                            data-exp-tab
                            data-target={item.id}
                            aria-controls={item.id}
                            aria-selected={index === 0 ? 'true' : 'false'}
                        >
                            <div class="flex gap-x-3 items-center">
                                {
                                    item.companyImage && (
                                        <img
                                            src={item.companyImage}
                                            class="h-auto w-6 rounded-md object-contain"
                                            alt={`${item.company} logo`}
                                            loading="lazy"
                                        />
                                    )
                                }
                                <p class="text-sm font-semibold">{item.company}</p>
                            </div>
                            <p class="mt-1 text-xs opacity-70">
                                {item.role}
                            </p>
                        </button>
                    ))
                }
            </div>
        </aside>

        <div class="md:w-9/12">
            {
                renderedItems.map((item, index) => (
                    <article
                        id={item.id}
                        data-exp-panel
                        class:list={[index === 0 ? 'block' : 'hidden']}
                    >
                        <h3 class="text-2xl font-semibold tracking-tight text-slate-950">
                            {item.role}
                        </h3>
                        <p class="mt-2 text-sm text-slate-500">
                            {item.company} · {item.period}
                        </p>
                        <div
                            class="mt-6 text-base leading-relaxed text-slate-700 [&>p]:m-0 [&_strong]:font-semibold [&_strong]:text-slate-900"
                            set:html={item.renderedSummary}
                        />
                        <ul class="mt-6 space-y-3 text-base leading-relaxed text-slate-700">
                            {item.renderedResponsibilities.map((bullet) => (
                                <li class="flex items-start gap-3">
                                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-slate-400" />
                                    <div
                                        class="flex-1 [&>p]:m-0 [&_strong]:font-semibold [&_strong]:text-slate-900"
                                        set:html={bullet}
                                    />
                                </li>
                            ))}
                        </ul>
                        <div class="mt-6">
                            <p class="text-sm text-slate-500">{stackLabel}</p>
                            <div class="mt-3 flex flex-wrap gap-2.5">
                                {item.techBadges.map((tech) => (
                                    <span class="inline-flex items-center gap-2 rounded-full border border-indigo-200/70 bg-indigo-50/70 px-3 py-1.5 text-sm text-indigo-950 shadow-sm shadow-indigo-100/80">
                                        {tech.iconName ? (
                                            <Icon
                                                name={tech.iconName}
                                                class="h-4 w-4 shrink-0 text-indigo-700"
                                                aria-hidden="true"
                                            />
                                        ) : (
                                            <span class="inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] bg-indigo-200 text-[10px] font-semibold leading-none text-indigo-800">
                                                {tech.fallback}
                                            </span>
                                        )}
                                        <span>{tech.label}</span>
                                    </span>
                                ))}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<script is:inline>
    const tabButtons = Array.from(document.querySelectorAll('[data-exp-tab]'));
    const panels = Array.from(document.querySelectorAll('[data-exp-panel]'));

    function activateExperience(targetId) {
        tabButtons.forEach((button) => {
            const selected = button.getAttribute('data-target') === targetId;
            button.setAttribute('aria-selected', selected ? 'true' : 'false');
            button.classList.toggle('border-indigo-600', selected);
            button.classList.toggle('bg-indigo-50/70', selected);
            button.classList.toggle('text-indigo-950', selected);
            button.classList.toggle('border-slate-200', !selected);
            button.classList.toggle('text-slate-500', !selected);
        });

        panels.forEach((panel) => {
            panel.classList.toggle('hidden', panel.id !== targetId);
            panel.classList.toggle('block', panel.id === targetId);
        });
    }

    tabButtons.forEach((button) => {
        button.addEventListener('click', () => {
            const targetId = button.getAttribute('data-target');
            if (!targetId) return;
            activateExperience(targetId);
        });
    });
</script>
