---
import { ExternalLink } from '@lucide/astro';
import { getWhyHireMeContent } from '@/data/why-hire-me';
import { DEFAULT_LOCALE } from '@/i18n/locales';

const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const certifications = getWhyHireMeContent(locale).certifications;
const sectionTitle = certifications.title;
const credentialText = certifications.viewCredentialLabel;
const cards = certifications.items.map((item) => {
    const shouldTruncate =
        item.description.length > certifications.previewLength;
    const preview = shouldTruncate
        ? `${item.description.slice(0, certifications.previewLength).trimEnd()}...`
        : item.description;

    return {
        ...item,
        preview,
        shouldTruncate,
    };
});
---

<section
    id="certifications-section"
    class="mt-24"
>
    <div class="max-w-3xl">
        <h2 class="text-4xl font-bold tracking-tight text-indigo-700">
            {sectionTitle}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600">
            {certifications.description}
        </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
            cards.map((item) => (
                <article class="flex h-full flex-col rounded-xl border border-indigo-100 bg-gradient-to-br from-white via-indigo-50/30 to-white p-5">
                    <div class="flex items-start gap-4">
                        <img
                            src={item.icon}
                            class="h-11 w-auto shrink-0 object-contain"
                            alt={item.title}
                        />

                        <h3 class="text-base font-semibold leading-snug text-slate-900">
                            {item.title}
                        </h3>
                    </div>
                    <div class="mt-4">
                        <p class="text-sm leading-relaxed text-slate-600">
                            <span
                                data-cert-preview
                                data-cert-id={item.id}
                            >
                                {item.preview}
                            </span>
                            <span
                                class="hidden"
                                data-cert-full
                                data-cert-id={item.id}
                            >
                                {item.description}
                            </span>
                            {item.shouldTruncate && (
                                <>
                                    <button
                                        type="button"
                                        class="ml-1 inline-flex align-baseline text-xs font-medium text-indigo-700 transition-colors hover:text-indigo-900"
                                        data-cert-toggle
                                        data-cert-id={item.id}
                                        aria-expanded="false"
                                    >
                                        {certifications.viewMoreLabel}
                                    </button>
                                </>
                            )}
                        </p>
                    </div>

                    <a
                        class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-indigo-800 transition-colors hover:text-indigo-950"
                        href={item.href}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {credentialText}
                        <ExternalLink
                            size={15}
                            stroke-width={2}
                        />
                    </a>
                </article>
            ))
        }
    </div>
</section>

<script
    is:inline
    define:vars={{
        viewMoreLabel: certifications.viewMoreLabel,
        viewLessLabel: certifications.viewLessLabel,
    }}
>
    const certToggles = Array.from(
        document.querySelectorAll('[data-cert-toggle]'),
    );

    certToggles.forEach((button) => {
        button.addEventListener('click', () => {
            const certId = button.getAttribute('data-cert-id');
            if (!certId) return;

            const preview = document.querySelector(
                `[data-cert-preview][data-cert-id="${certId}"]`,
            );
            const full = document.querySelector(
                `[data-cert-full][data-cert-id="${certId}"]`,
            );
            if (
                !(preview instanceof HTMLElement) ||
                !(full instanceof HTMLElement)
            ) {
                return;
            }

            const isExpanded = button.getAttribute('aria-expanded') === 'true';
            button.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
            button.textContent = isExpanded ? viewMoreLabel : viewLessLabel;
            preview.classList.toggle('hidden', !isExpanded);
            full.classList.toggle('hidden', isExpanded);
        });
    });
</script>
