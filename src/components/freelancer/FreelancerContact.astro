---
import type { FreelancerContactContent } from '@/types/freelancer';
import { DEFAULT_LOCALE } from '@/i18n/locales';

interface Props {
    content: FreelancerContactContent;
}

const { content } = Astro.props;
const typeformUrl = 'https://form.typeform.com/to/vOVcAa4H';
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const contactCta =
    locale === 'es'
        ? {
              responseTime: 'Te respondo en menos de 24 horas.',
              buttonLabel: 'Enviar consulta',
          }
        : {
              responseTime: 'I will reply in less than 24 hours.',
              buttonLabel: 'Send inquiry',
          };
---

<section id="contact" class="scroll-mt-28 bg-background-secondary px-6 py-20 md:px-10 md:py-24">
    <div class="mx-auto max-w-[1040px]">
        <div class="grid gap-10 lg:grid-cols-[1fr_340px] lg:items-center">
            <div>
                <h2 class="text-[34px] font-bold tracking-[-0.03em] text-white md:text-[42px]">
                    {content.title}
                </h2>
                <p class="mt-3 max-w-[520px] text-[15px] leading-7 text-[#96a6c1]">
                    {content.description}
                </p>
            </div>

            <div>
                <p class="text-[14px] font-semibold leading-6 text-[#96a6c1]">
                    {contactCta.responseTime}
                </p>
                <a
                    href={typeformUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-6 inline-flex w-full items-center justify-center rounded-[16px] bg-primary px-6 py-5 text-[17px] font-bold text-white transition hover:bg-primary-600"
                >
                    {contactCta.buttonLabel}
                </a>
            </div>
        </div>
    </div>
</section>
