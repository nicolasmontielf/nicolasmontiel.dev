---
import type { FreelancerFaqContent } from '@/types/content';

interface Props {
    content: FreelancerFaqContent;
}

const { content } = Astro.props;
---

<section class="px-6 py-20 md:px-10 md:py-24">
    <div class="mx-auto max-w-[610px]">
        <div class="text-center">
            <span class="inline-flex rounded-full bg-[#2d3442] px-3 py-1 text-[10px] font-semibold text-[#d8dbe4]">
                {content.badgeLabel}
            </span>
            <h2 class="mt-5 text-[34px] font-bold tracking-[-0.03em] text-white md:text-[42px]">
                {content.title}
            </h2>
            <p class="mx-auto mt-3 max-w-[520px] text-[15px] text-[#96a6c1]">
                {content.description}
            </p>
        </div>

        <div class="mt-10 divide-y divide-[#273146] border-y border-[#273146]">
            {
                content.items.map((item) => (
                    <div class="flex items-center justify-between py-5">
                        <p class="text-[14px] font-semibold text-white">
                            {item.question}
                        </p>
                        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-[#273146] text-[14px] text-[#dbe4f5]">
                            +
                        </span>
                    </div>
                ))
            }
        </div>
    </div>
</section>
