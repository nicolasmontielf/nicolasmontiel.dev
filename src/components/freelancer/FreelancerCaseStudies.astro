---
import type { FreelancerCaseStudiesContent } from '@/types/freelancer';
import type { Locale } from '@/i18n/locales';

interface Props {
    locale: Locale;
    content: FreelancerCaseStudiesContent;
}

const { locale, content } = Astro.props;
---

<section id="case-studies" class="scroll-mt-28 bg-background-secondary px-6 py-20 md:px-10 md:py-24">
    <div class="mx-auto max-w-[1040px]">
        <div class="text-center">
            <span class="inline-flex rounded-full bg-primary-900 px-3 py-1 text-[10px] font-semibold text-primary-200">
                {content.badgeLabel}
            </span>
            <h2 class="mt-5 text-[34px] font-bold tracking-[-0.03em] text-white md:text-[42px]">
                {content.title}
            </h2>
            <p class="mx-auto mt-3 max-w-[640px] text-[15px] text-[#96a6c1]">
                {content.description}
            </p>
        </div>

        <div class="mt-14 grid gap-4 lg:grid-cols-2">
            {
                content.items.map((item) => (
                    <article class="overflow-hidden rounded-[12px] bg-[#151e31]">
                        <div class="relative h-[230px] overflow-hidden">
                            <img
                                src={item.imageSrc}
                                alt={item.imageAlt}
                                class="h-full w-full object-cover"
                                loading="lazy"
                            />
                            <span class="absolute left-3 top-3 rounded-full bg-[#3b4558] px-2.5 py-1 text-[10px] font-semibold text-white">
                                {item.category}
                            </span>
                        </div>
                        <div class="p-4">
                            <h3 class="text-[30px] font-bold tracking-[-0.03em] text-white">
                                {item.title}
                            </h3>
                            <p class="mt-2 text-[14px] leading-6 text-[#96a6c1]">
                                {item.previewText}
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                                {
                                    item.technologies.map((tag) => (
                                        <span class="rounded-[5px] bg-primary-800 px-2 py-1 text-[10px] font-semibold text-primary-100">
                                            {tag}
                                        </span>
                                    ))
                                }
                            </div>
                            <a
                                href={`/${locale}/case-studies/${item.slug}`}
                                class="mt-4 inline-flex items-center gap-2 text-[13px] font-semibold text-primary-300"
                            >
                                {content.ctaLabel}
                                <span aria-hidden="true">&rarr;</span>
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
