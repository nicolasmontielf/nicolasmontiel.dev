---
import type { FreelancerTestimonialsContent } from '@/types/content';

interface Props {
    content: FreelancerTestimonialsContent;
}

const { content } = Astro.props;
---

<section class="px-6 py-20 md:px-10 md:py-24">
    <div class="mx-auto max-w-[1040px]">
        <div class="text-center">
            <span class="inline-flex rounded-full bg-primary-900 px-3 py-1 text-[10px] font-semibold text-primary-200">
                {content.badgeLabel}
            </span>
            <h2 class="mt-5 text-[34px] font-bold tracking-[-0.03em] text-white md:text-[42px]">
                {content.title}
            </h2>
            <p class="mx-auto mt-3 max-w-[640px] text-[15px] text-[#96a6c1]">
                {content.description}
            </p>
        </div>

        <div class="relative mt-14">
            <button
                type="button"
                aria-label="Previous testimonials"
                class="absolute left-[-12px] top-1/2 z-10 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-[#2b3548] text-[#a6b5cd] lg:flex"
            >
                &lt;
            </button>
            <button
                type="button"
                aria-label="Next testimonials"
                class="absolute right-[-12px] top-1/2 z-10 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-[#2b3548] text-[#a6b5cd] lg:flex"
            >
                &gt;
            </button>

            <div class="grid gap-4 lg:grid-cols-3">
                {
                    content.items.map((item) => (
                        <article class="rounded-[12px] bg-[#151e31] p-5">
                            <p class="mt-4 text-[14px] leading-6 text-[#d8e0ef]">
                                {item.quote}
                            </p>
                            <div class="mt-5 flex items-center gap-3">
                                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[#6f42da] text-[12px] font-bold text-white">
                                    {item.initial}
                                </div>
                                <div>
                                    <p class="text-[13px] font-semibold text-white">
                                        {item.author}
                                    </p>
                                    <p class="text-[11px] text-[#8293af]">
                                        {item.role}
                                    </p>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="mt-6 flex items-center justify-center gap-2">
                <span class="h-1.5 w-4 rounded-full bg-[#d8dbe4]"></span>
                <span class="h-1.5 w-1.5 rounded-full bg-[#5a6478]"></span>
                <span class="h-1.5 w-1.5 rounded-full bg-[#5a6478]"></span>
                <span class="h-1.5 w-1.5 rounded-full bg-[#5a6478]"></span>
            </div>
        </div>
    </div>
</section>
