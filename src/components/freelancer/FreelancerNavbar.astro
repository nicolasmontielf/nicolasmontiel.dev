---
import logo from '@assets/logo.png';
import type { FreelancerNavbarContent } from '@/types/content';
import type { Locale } from '@/i18n/locales';

interface Props {
    locale: Locale;
    content: FreelancerNavbarContent;
}

const { locale, content } = Astro.props;
---

<header class="border-b border-white/10 bg-background-primary">
    <div class="mx-auto flex min-h-[100px] max-w-[1640px] items-center justify-between gap-8 px-6 md:px-10 xl:px-[54px]">
        <a
            href={`/${locale}`}
            class="inline-flex shrink-0 items-center"
        >
            <img
                src={logo.src}
                alt="Nicolas Montiel"
                class="h-12 w-auto"
                width={logo.width}
                height={logo.height}
            />
        </a>

        <nav class="hidden flex-1 items-center justify-center gap-5 xl:flex">
            {
                content.items.map((item) => (
                    <a
                        href="#"
                        class:list={[
                            'text-[14px] font-semibold tracking-[-0.01em] transition 2xl:text-[15px]',
                            item === 'Services'
                                ? 'text-white'
                                : 'text-[#909aac] hover:text-white',
                        ]}
                    >
                        {item}
                    </a>
                ))
            }
        </nav>

        <a
            href="#"
            class="inline-flex h-[52px] shrink-0 items-center justify-center rounded-[12px] bg-primary px-8 text-[17px] font-bold text-white shadow-[0_14px_34px_rgba(67,56,202,0.28)] transition hover:bg-primary-600"
        >
            {content.ctaLabel}
        </a>
    </div>
</header>
