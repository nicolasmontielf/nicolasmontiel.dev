---
import { Globe, Palette, Rocket, Sparkles } from '@lucide/astro';
import type {
    FreelancerServiceIcon,
    FreelancerServicesContent,
} from '@/types/freelancer';

interface Props {
    content: FreelancerServicesContent;
}

const { content } = Astro.props;
const iconByName: Record<FreelancerServiceIcon, typeof Globe> = {
    globe: Globe,
    sparkles: Sparkles,
    palette: Palette,
    rocket: Rocket,
};
---

<section class="bg-background-secondary px-6 py-20 md:px-10 md:py-24">
    <div class="mx-auto max-w-[1040px]">
        <div class="text-center">
            <span class="inline-flex rounded-full bg-primary-900 px-3 py-1 text-[10px] font-semibold text-primary-200">
                {content.badgeLabel}
            </span>
            <h2 class="mt-5 text-[34px] font-bold tracking-[-0.03em] text-white md:text-[42px]">
                {content.title}
            </h2>
            <p class="mx-auto mt-3 max-w-[640px] text-[15px] text-[#96a6c1]">
                {content.description}
            </p>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
            {
                content.items.map((item) => {
                    const IconComponent = iconByName[item.icon];

                    return (
                        <article class="rounded-[12px] bg-[#232d3e] p-6">
                            <div class="flex h-12 w-12 items-center justify-center rounded-[10px] bg-primary-900 text-primary-200">
                                <IconComponent class="h-5 w-5" />
                            </div>
                            <h3 class="mt-5 text-[24px] font-bold tracking-[-0.03em] text-white">
                                {item.title}
                            </h3>
                            <p class="mt-4 text-[14px] leading-6 text-[#b5c2d8]">
                                {item.description}
                            </p>
                        </article>
                    );
                })
            }
        </div>
    </div>
</section>
