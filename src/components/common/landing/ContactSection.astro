---
import { DEFAULT_LOCALE } from '@/i18n/locales';
import type { SharedContactSectionProps } from '@/types/contact-form';
import ContactForm from '@components/common/landing/ContactForm';

const { contact, whatsappLink, containerClass, source } =
    Astro.props as SharedContactSectionProps;
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isTurnstileEnabled = !import.meta.env.DEV && Boolean(turnstileSiteKey);
---

<section
    id="contact"
    class="bg-white py-16 md:py-20"
>
    <div
        class={`${containerClass} grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start`}
    >
        <div>
            <p
                class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600"
            >
                {contact.eyebrow}
            </p>
            <h2
                class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl"
            >
                {contact.title}
            </h2>
            <p class="mt-4 max-w-xl text-base leading-relaxed text-slate-600">
                {contact.description}
            </p>

            <div
                class="mt-8 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.15)]"
            >
                <p class="text-sm leading-relaxed text-slate-600">
                    {contact.whatsappNote}
                </p>
                <a
                    href={whatsappLink}
                    target="_blank"
                    rel="noreferrer"
                    class="mt-5 inline-flex rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
                >
                    {contact.whatsappCtaLabel}
                </a>
            </div>
        </div>

        <div
            class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.15)] md:p-8"
        >
            <p
                class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-500"
            >
                {contact.formTitle}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
                {contact.formDescription}
            </p>

            <ContactForm
                client:load
                contact={contact}
                locale={locale}
                source={source}
                isTurnstileEnabled={isTurnstileEnabled}
                turnstileSiteKey={turnstileSiteKey}
            />
        </div>
    </div>
</section>

{
    isTurnstileEnabled && (
        <script
            is:inline
            src="https://challenges.cloudflare.com/turnstile/v0/api.js"
            async
            defer
        />
    )
}
