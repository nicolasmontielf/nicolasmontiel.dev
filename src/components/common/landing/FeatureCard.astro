---
type Props = {
    title: string;
    description: string;
    layout?: 'stacked' | 'inline' | 'text';
    accentLabel?: string;
    hoverable?: boolean;
    className?: string;
};

const {
    title,
    description,
    layout = 'text',
    accentLabel,
    hoverable = false,
    className,
} = Astro.props as Props;
const hasIcon = Astro.slots.has('icon');
---

<article
    class:list={[
        'rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]',
        hoverable &&
            'transition hover:-translate-y-1 hover:border-indigo-200 hover:bg-white hover:shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]',
        className,
    ]}
>
    {accentLabel && (
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-indigo-600">
            {accentLabel}
        </p>
    )}

    {
        layout === 'stacked' && (
            <>
                {hasIcon && <slot name="icon" />}
                <h3 class="mt-5 text-xl font-semibold tracking-tight text-slate-950">
                    {title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                    {description}
                </p>
            </>
        )
    }

    {
        layout === 'inline' && (
            <>
                <div class="flex items-center gap-3">
                    {hasIcon && <slot name="icon" />}
                    <h3 class="text-lg font-semibold leading-snug tracking-tight text-slate-900">
                        {title}
                    </h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                    {description}
                </p>
            </>
        )
    }

    {
        layout === 'text' && (
            <>
                <h3 class="text-lg font-semibold tracking-tight text-slate-900">
                    {title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                    {description}
                </p>
            </>
        )
    }
</article>
