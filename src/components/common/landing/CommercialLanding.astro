---
import ContactSection from '@components/common/landing/ContactSection.astro';
import Footer from '@components/common/landing/Footer.astro';
import LandingNavbar from '@components/common/landing/LandingNavbar.astro';
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import {
    landingContainerClass,
    landingLabelClass,
    landingPrimaryButtonClass,
    landingSecondaryButtonClass,
} from '@components/common/landing/styles';
import type { CommercialLandingProps } from '@/types/landing/props';
import type {
    EcommerceLandingContent,
    WebLandingIconName,
    WebLandingContent,
} from '@/types/landing/content';
import {
    FolderOpen,
    Globe,
    MessageCircle,
    Search,
    Shield,
} from '@lucide/astro';

const { content, source, heroVideo, heroPoster, heroImageAlt } =
    Astro.props as CommercialLandingProps;
const secondCtaAnchor = source === 'web' ? '#solutions' : '#challenges';
const isWeb = source === 'web';
const webContent = isWeb ? (content as WebLandingContent) : null;
const ecommerceContent = !isWeb ? (content as EcommerceLandingContent) : null;
const webIconByName: Record<WebLandingIconName, any> = {
    globe: Globe,
    'folder-open': FolderOpen,
    search: Search,
    'message-circle': MessageCircle,
    shield: Shield,
    'building-2': Globe,
    megaphone: Globe,
    'book-open': Globe,
    'sliders-horizontal': Globe,
    'calendar-clock': Globe,
    'chart-column': Globe,
    handshake: Globe,
    'clipboard-list': Globe,
    palette: Globe,
    code: Globe,
    check: Globe,
    rocket: Globe,
};
const webProcessPairs = webContent
    ? webContent.process.steps.reduce<
          Array<{
              left: (typeof webContent.process.steps)[number];
              right?: (typeof webContent.process.steps)[number];
              leftIndex: number;
              rightIndex?: number;
          }>
      >((acc, _step, index, steps) => {
          if (index % 2 === 0) {
              acc.push({
                  left: steps[index],
                  right: steps[index + 1],
                  leftIndex: index,
                  rightIndex:
                      index + 1 < steps.length ? index + 1 : undefined,
              });
          }
          return acc;
      }, [])
    : [];
---

<div class="bg-white text-slate-700">
    <LandingNavbar
        nav={content.nav}
        whatsappLink={content.links.whatsapp}
        ctaLabel={content.hero.primaryCtaLabel}
        containerClass={landingContainerClass}
    />

    <main>
        <section
            id="hero"
            class="overflow-hidden bg-[radial-gradient(circle_at_8%_18%,rgba(99,102,241,0.16),transparent_35%),linear-gradient(140deg,#ffffff_0%,#f8fafc_44%,#eef4ff_100%)] py-16 md:py-24"
        >
            <div
                class={`${landingContainerClass} grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(360px,460px)] lg:items-center`}
            >
                <div>
                    <p class={landingLabelClass}>{content.hero.badge}</p>
                    <h1
                        class="mt-6 max-w-3xl text-4xl font-bold tracking-tight text-slate-950 md:text-6xl md:leading-[1.02]"
                    >
                        {content.hero.title}
                    </h1>
                    <p
                        class="mt-6 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg"
                    >
                        {content.hero.description}
                    </p>

                    <div class="mt-8 flex flex-wrap gap-3">
                        <a
                            href={content.links.whatsapp}
                            target="_blank"
                            rel="noreferrer"
                            class:list={[
                                landingPrimaryButtonClass,
                                'inline-flex items-center gap-2',
                            ]}
                        >
                            <MessageCircle
                                size={16}
                                stroke-width={2}
                            />
                            {content.hero.primaryCtaLabel}
                        </a
                        >
                        <a
                            href={secondCtaAnchor}
                            class={landingSecondaryButtonClass}
                            >{content.hero.secondaryCtaLabel}</a
                        >
                    </div>

                    {
                        !isWeb && content.hero.note && (
                            <p class="mt-7 max-w-xl border-l-2 border-indigo-300 pl-4 text-sm leading-relaxed text-slate-500">
                                {content.hero.note}
                            </p>
                        )
                    }
                </div>

                <div class="relative mx-auto w-full max-w-md">
                    <div
                        class="rounded-[1.75rem] border border-slate-200 p-4 shadow-[0_24px_70px_-45px_rgba(15,23,42,0.42)]"
                    >
                        <video
                            class="w-full rounded-[1.2rem] object-cover"
                            autoplay
                            loop
                            muted
                            playsinline
                            poster={heroPoster}
                            aria-label={heroImageAlt}
                        >
                            <source
                                src={heroVideo}
                                type="video/webm"
                            />
                        </video>
                    </div>
                </div>
            </div>
        </section>

        <section id="challenges" class="bg-white py-16 md:py-20">
            <div class={landingContainerClass}>
                {
                    isWeb ? (
                        <>
                            <div class="max-w-3xl">
                                <p class={landingLabelClass}>
                                    {content.challenges.eyebrow}
                                </p>
                                <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl">
                                    {content.challenges.title}
                                </h2>
                                <p class="mt-5 text-base leading-relaxed text-slate-600">
                                    {content.challenges.description}
                                </p>
                            </div>

                            <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                                {webContent?.challenges.items.map((item) => (
                                    <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)] transition hover:-translate-y-1 hover:border-indigo-200 hover:bg-white">
                                        <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500">
                                            {(() => {
                                                const Icon = webIconByName[
                                                    item.icon
                                                ];
                                                return (
                                                    <Icon
                                                        size={18}
                                                        strokeWidth={1.9}
                                                    />
                                                );
                                            })()}
                                        </div>
                                        <h3 class="mt-5 text-xl font-semibold tracking-tight text-slate-950">
                                            {item.title}
                                        </h3>
                                        <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                            {item.description}
                                        </p>
                                    </article>
                                ))}
                            </div>
                        </>
                    ) : (
                        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-start">
                            <div class="grid gap-5 md:grid-cols-2">
                                {content.challenges.items.map((item, index) => (
                                    <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]">
                                        <div class="flex items-center gap-3">
                                            <span class="grid h-9 w-9 place-items-center rounded-xl bg-indigo-600 text-sm font-semibold text-white">
                                                {index + 1}
                                            </span>
                                            <h3 class="text-lg font-semibold tracking-tight text-slate-900">
                                                {item.title}
                                            </h3>
                                        </div>
                                        <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                            {item.description}
                                        </p>
                                    </article>
                                ))}
                            </div>

                            <div>
                                <p class={landingLabelClass}>
                                    {content.challenges.eyebrow}
                                </p>
                                <h2 class="mt-4 text-2xl font-bold tracking-tight text-slate-950 md:text-4xl">
                                    {content.challenges.title}
                                </h2>
                                <p class="mt-5 text-base leading-relaxed text-slate-600">
                                    {content.challenges.description}
                                </p>
                            </div>
                        </div>
                    )
                }
            </div>
        </section>

        <section id="solutions" class="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20">
            <div class={landingContainerClass}>
                <div class="max-w-3xl">
                    <p class={landingLabelClass}>{content.solutions.eyebrow}</p>
                    <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl">
                        {content.solutions.title}
                    </h2>
                    <p class="mt-5 text-base leading-relaxed text-slate-600">
                        {content.solutions.description}
                    </p>
                </div>

                {
                    isWeb ? (
                        <>
                            <div class="mt-10 overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-[0_24px_60px_-42px_rgba(15,23,42,0.24)]">
                                <table class="hidden w-full border-collapse md:table">
                                    <thead class="bg-slate-50">
                                        <tr class="text-left">
                                            <th class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                                                {webContent?.solutions.columns.solution}
                                            </th>
                                            <th class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                                                {webContent?.solutions.columns.objective}
                                            </th>
                                            <th class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                                                {webContent?.solutions.columns.outcome}
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {webContent?.solutions.rows.map((row) => (
                                            <tr class="group transition hover:bg-slate-50/70">
                                                <td class="w-[24%] px-6 py-5 align-top">
                                                    <div class="flex items-start gap-3">
                                                        <p class="text-[15px] font-semibold leading-snug text-slate-950">
                                                            {row.solution}
                                                        </p>
                                                    </div>
                                                    {
                                                        row.href && (
                                                            <a
                                                                href={row.href}
                                                                class="mt-3 inline-flex rounded-md border border-indigo-200 bg-indigo-50 px-3 py-2 text-xs font-semibold text-indigo-700 transition hover:border-indigo-300 hover:bg-indigo-100"
                                                            >
                                                                {row.hrefLabel ??
                                                                    'Ver más'}
                                                            </a>
                                                        )
                                                    }
                                                </td>
                                                <td class="w-[38%] px-6 py-5 align-top text-sm leading-relaxed text-slate-600">
                                                    {row.objective}
                                                </td>
                                                <td class="w-[38%] px-6 py-5 align-top text-sm leading-relaxed text-slate-700">
                                                    <p>{row.outcome}</p>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>

                                <div class="grid gap-px bg-slate-200 md:hidden">
                                    {webContent?.solutions.rows.map((row) => (
                                        <article class="bg-white p-5">
                                            <h3 class="text-base font-semibold tracking-tight text-slate-950">
                                                {row.solution}
                                            </h3>
                                            {
                                                row.href && (
                                                    <a
                                                        href={row.href}
                                                        class="mt-3 inline-flex rounded-md border border-indigo-200 bg-indigo-50 px-3 py-2 text-xs font-semibold text-indigo-700 transition hover:border-indigo-300 hover:bg-indigo-100"
                                                    >
                                                        {row.hrefLabel ??
                                                            'View more'}
                                                    </a>
                                                )
                                            }
                                            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
                                                {webContent?.solutions.columns.objective}
                                            </p>
                                            <p class="mt-1 text-sm leading-relaxed text-slate-600">
                                                {row.objective}
                                            </p>
                                            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-indigo-700">
                                                {webContent?.solutions.columns.outcome}
                                            </p>
                                            <p class="mt-1 text-sm leading-relaxed text-slate-700">
                                                {row.outcome}
                                            </p>
                                        </article>
                                    ))}
                                </div>
                            </div>
                        </>
                    ) : (
                        <div class="mt-10 grid gap-px overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-200 md:grid-cols-2 lg:grid-cols-3">
                            {ecommerceContent?.solutions.items.map((item) => (
                                <article class="bg-white p-6 transition hover:bg-slate-50">
                                    <h3 class="text-lg font-semibold tracking-tight text-slate-950">
                                        {item.title}
                                    </h3>
                                    <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                        {item.description}
                                    </p>
                                </article>
                            ))}
                        </div>
                    )
                }
            </div>
        </section>

        <section id="process" class="bg-white py-16 md:py-20">
            <div class={landingContainerClass}>
                <div class="max-w-2xl">
                    <p class={landingLabelClass}>{content.process.eyebrow}</p>
                    <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">
                        {content.process.title}
                    </h2>
                    <p class="mt-4 text-base leading-relaxed text-slate-600">
                        {content.process.description}
                    </p>
                </div>

                {
                    isWeb ? (
                        <ol class="mt-10 grid gap-8">
                            {webProcessPairs.map((pair) => (
                                <li class="relative">
                                    <div class="grid gap-4 lg:grid-cols-2 lg:items-start">
                                        <article class="relative rounded-[1.25rem] border border-slate-200 bg-white p-5 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]">
                                            <span class="absolute -left-3 -top-3 grid h-9 w-9 place-items-center rounded-full border-2 border-indigo-200 bg-white text-xs font-bold text-indigo-700">
                                                {pair.leftIndex + 1}
                                            </span>
                                            <h3 class="text-lg font-semibold tracking-tight text-slate-950">
                                                {pair.left.title}
                                            </h3>
                                            <p class="mt-2 text-sm leading-relaxed text-slate-600">
                                                {pair.left.description}
                                            </p>
                                        </article>

                                        {pair.right && (
                                            <article class="relative rounded-[1.25rem] border border-slate-200 bg-white p-5 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)] lg:translate-y-8">
                                                <span class="absolute -left-3 -top-3 grid h-9 w-9 place-items-center rounded-full border-2 border-indigo-200 bg-white text-xs font-bold text-indigo-700">
                                                    {(pair.rightIndex ?? 0) + 1}
                                                </span>
                                                <h3 class="text-lg font-semibold tracking-tight text-slate-950">
                                                    {pair.right.title}
                                                </h3>
                                                <p class="mt-2 text-sm leading-relaxed text-slate-600">
                                                    {pair.right.description}
                                                </p>
                                            </article>
                                        )}
                                    </div>
                                </li>
                            ))}
                        </ol>
                    ) : (
                        <ol class="relative mt-12 grid gap-5 md:grid-cols-2">
                            <div class="pointer-events-none absolute left-6 top-6 hidden h-[calc(100%-3rem)] w-px bg-gradient-to-b from-indigo-200 via-indigo-100 to-transparent md:block">
                            </div>
                            {ecommerceContent?.process.steps.map((step, index) => (
                                <li
                                    class:list={[
                                        'relative rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-[0_20px_45px_-34px_rgba(15,23,42,0.18)]',
                                        index % 2 === 1 && 'md:translate-y-10',
                                    ]}
                                >
                                    <div class="flex items-start gap-4">
                                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-indigo-600 text-sm font-semibold text-white shadow-[0_12px_30px_-18px_rgba(79,70,229,0.9)]">
                                            {index + 1}
                                        </div>
                                        <div>
                                            <h3 class="text-xl font-semibold tracking-tight text-slate-950">
                                                {step.title}
                                            </h3>
                                            <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                                {step.description}
                                            </p>
                                        </div>
                                    </div>
                                </li>
                            ))}
                        </ol>
                    )
                }
            </div>
        </section>

        <SharedProfileSection
            profile={content.profile}
            aboutLink={content.links.about}
            containerClass={landingContainerClass}
            sectionId="profile"
            sectionClass="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)]"
        />

        <ContactSection
            contact={content.contact}
            whatsappLink={content.links.whatsapp}
            containerClass={landingContainerClass}
            source={source}
            sectionClass="bg-white"
        />
    </main>

    <Footer />
</div>
