---
import FeatureCard from '@components/common/landing/FeatureCard.astro';
import LandingButtonLink from '@components/common/landing/LandingButtonLink.astro';
import { resolveLocale } from '@/i18n/locales';
import { getMessages } from '@/i18n/messages';
import type { SharedProfileSectionProps } from '@/types/landing/props';
import avatarImage from '@assets/nicolas-montiel-avatar.png';

const {
    profile,
    aboutLink,
    containerClass,
    sectionId = 'profile',
    sectionClass = 'bg-white',
} = Astro.props as SharedProfileSectionProps;
const locale = resolveLocale(Astro.locals.locale);
const labels = getMessages(locale).landing;
const avatarSrc = avatarImage.src;
const avatarAlt = labels.avatarAlt;
---

<section
    id={sectionId}
    class:list={[sectionClass, 'py-16 md:py-20']}
>
    <div
        class={`${containerClass} grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start`}
    >
        <div
            class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.22)]"
        >
            <div class="flex items-center gap-4">
                <img
                    src={avatarSrc}
                    alt={avatarAlt}
                    class="h-14 w-14 rounded-full border border-slate-200 object-cover"
                    loading="lazy"
                />
                <div>
                    <p
                        class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600"
                    >
                        {profile.eyebrow}
                    </p>
                    <p class="mt-1 text-sm font-medium text-slate-500">
                        Nicolás Montiel
                    </p>
                </div>
            </div>

            <h2
                class="mt-6 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl"
            >
                {profile.title}
            </h2>
            <p class="mt-4 leading-relaxed text-slate-600">
                {profile.description}
            </p>
            <LandingButtonLink
                href={aboutLink}
                variant="secondary"
                className="mt-8 inline-flex rounded-md border-slate-200 bg-slate-50 text-slate-900 hover:border-slate-300 hover:bg-slate-100"
            >
                {profile.buttonLabel}
            </LandingButtonLink>
        </div>

        <div class="grid gap-5">
            {
                profile.items.map((item) => (
                    <FeatureCard
                        title={item.title}
                        description={item.description}
                        className="shadow-[0_18px_40px_-34px_rgba(15,23,42,0.16)]"
                    />
                ))
            }
        </div>
    </div>
</section>
