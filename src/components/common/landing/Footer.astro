---
import logo from '@/assets/logo.png';
import { resolveLocale } from '@/i18n/locales';
import { getWhatsappLink } from '@/i18n/links';
import { getMessages } from '@/i18n/messages';
import { getAboutPath, getCommercialServicePath } from '@/i18n/routing';

const locale = resolveLocale(Astro.locals.locale);
const aboutPath = getAboutPath(locale);
const ecommercePath = getCommercialServicePath('ecommerce', locale);
const webPath = getCommercialServicePath('web', locale);
const whatsappLink = getWhatsappLink(locale);
const { common, footer } = getMessages(locale);
---

<footer class="border-t border-slate-200 bg-white py-10">
    <div
        class="mx-auto grid w-full max-w-[1120px] gap-8 px-4 text-sm text-slate-600 sm:px-6 md:grid-cols-3 md:items-start lg:px-8"
    >
        <div>
            <img
                src={logo.src}
                alt={footer.logoAlt}
                class="h-14 w-auto object-contain"
                loading="lazy"
            />
        </div>

        <nav>
            <p
                class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600"
            >
                {footer.contactTitle}
            </p>
            <div class="mt-4 flex flex-col items-start gap-3">
                <a
                    href="mailto:nicolasmontielf@gmail.com"
                    class="transition-colors hover:text-slate-950"
                >
                    {common.email}
                </a>
                <a
                    href={whatsappLink}
                    target="_blank"
                    rel="noreferrer"
                    class="transition-colors hover:text-slate-950"
                >
                    {common.whatsapp}
                </a>
                <a
                    href="https://www.linkedin.com/in/nicolasmontielf/?locale=en_US"
                    target="_blank"
                    rel="noreferrer"
                    class="transition-colors hover:text-slate-950"
                >
                    {common.linkedin}
                </a>
            </div>
        </nav>

        <nav>
            <p
                class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600"
            >
                {footer.linksTitle}
            </p>
            <div class="mt-4 flex flex-col items-start gap-3">
                <a
                    href={aboutPath}
                    class="transition-colors hover:text-slate-950"
                >
                    {footer.about}
                </a>
                <a
                    href={ecommercePath}
                    class="transition-colors hover:text-slate-950"
                >
                    {footer.ecommerce}
                </a>
                <a
                    href={webPath}
                    class="transition-colors hover:text-slate-950"
                >
                    {footer.web}
                </a>
            </div>
        </nav>
    </div>
</footer>
