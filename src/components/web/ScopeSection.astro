---
import { webContainerClass, webLabelClass } from '@components/web/styles';

type Props = {
	scope: {
		eyebrow: string;
		title: string;
		description: string;
		leftTitle: string;
		leftItems: string[];
		rightTitle: string;
		rightItems: string[];
	};
};

const { scope } = Astro.props as Props;
---

<section id="scope" class="border-y border-slate-200 bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20">
	<div class={`${webContainerClass} grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start`}>
		<div>
			<p class={webLabelClass}>{scope.eyebrow}</p>
			<h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl">{scope.title}</h2>
			<p class="mt-5 text-base leading-relaxed text-slate-600">{scope.description}</p>
		</div>

		<div class="grid gap-5 md:grid-cols-2">
			<article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_24px_70px_-50px_rgba(15,23,42,0.25)]">
				<div class="mb-5 h-2 w-20 rounded-full bg-slate-300"></div>
				<h3 class="text-xl font-semibold tracking-tight text-slate-950">{scope.leftTitle}</h3>
				<ul class="mt-6 space-y-4 text-sm leading-relaxed text-slate-600">
					{scope.leftItems.map((item) => <li class="border-t border-slate-100 pt-4">{item}</li>)}
				</ul>
			</article>

			<article class="rounded-[1.75rem] border border-indigo-200 bg-white p-6 shadow-[0_28px_80px_-50px_rgba(79,70,229,0.28)] md:translate-y-8">
				<div class="mb-5 h-2 w-20 rounded-full bg-indigo-500"></div>
				<h3 class="text-xl font-semibold tracking-tight text-slate-950">{scope.rightTitle}</h3>
				<ul class="mt-6 space-y-4 text-sm leading-relaxed text-slate-600">
					{scope.rightItems.map((item) => <li class="border-t border-indigo-100 pt-4">{item}</li>)}
				</ul>
			</article>
		</div>
	</div>
</section>
