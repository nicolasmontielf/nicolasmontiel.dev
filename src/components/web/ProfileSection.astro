---
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import type { WebProfileSectionProps } from '@/types/landing/props';
import { webContainerClass } from '@components/web/styles';
const { profile, aboutLink } = Astro.props as WebProfileSectionProps;
---

<SharedProfileSection
    profile={profile}
    aboutLink={aboutLink}
    containerClass={webContainerClass}
    sectionId="profile"
/>
