---
import type { WebBuildSectionProps } from '@/types/landing/props';
import { webContainerClass, webLabelClass } from '@components/web/styles';
const { build } = Astro.props as WebBuildSectionProps;
---

<section
    id="build"
    class="bg-white py-16 md:py-20"
>
    <div class={webContainerClass}>
        <div class="flex flex-col items-start gap-6 lg:gap-10">
            <div class="w-full lg:w-8/12">
                <p class={webLabelClass}>{build.eyebrow}</p>
                <h2
                    class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl"
                >
                    {build.title}
                </h2>
            </div>
            <p
                class="max-w-2xl text-base leading-relaxed text-slate-600 lg:justify-self-end"
            >
                {build.description}
            </p>
        </div>

        <div
            class="mt-10 grid gap-px overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-200 md:grid-cols-2 lg:grid-cols-3"
        >
            {
                build.capabilities.map((item) => (
                    <article class="bg-slate-50 p-6 transition hover:bg-white">
                        <div class="mb-8 h-10 w-10 rounded-2xl border border-indigo-200 bg-indigo-50" />
                        <h3 class="text-lg font-semibold tracking-tight text-slate-950">
                            {item.title}
                        </h3>
                        <p class="mt-3 text-sm leading-relaxed text-slate-600">
                            {item.description}
                        </p>
                    </article>
                ))
            }
        </div>
    </div>
</section>
