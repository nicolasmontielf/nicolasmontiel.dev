---
import type { WebProjectTypesSectionProps } from '@/types/landing/props';
import { webContainerClass, webLabelClass } from '@components/web/styles';
const { projects } = Astro.props as WebProjectTypesSectionProps;
---

<section
    id="projects"
    class="bg-white py-16 md:py-20"
>
    <div class={webContainerClass}>
        <div class="max-w-3xl">
            <p class={webLabelClass}>{projects.eyebrow}</p>
            <h2
                class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl"
            >
                {projects.title}
            </h2>
            <p class="mt-5 text-base leading-relaxed text-slate-600">
                {projects.description}
            </p>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {
                projects.items.map((item) => (
                    <article class="group relative min-h-[18rem] rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5 transition hover:-translate-y-1 hover:border-indigo-200 hover:bg-white hover:shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-indigo-600">
                            {item.accent}
                        </p>
                        <h3 class="mt-8 text-xl font-semibold tracking-tight text-slate-950">
                            {item.title}
                        </h3>
                        <p class="mt-4 text-sm leading-relaxed text-slate-600">
                            {item.description}
                        </p>
                        {item.href && (
                            <p class="mt-5 text-sm font-semibold text-indigo-600">
                                {item.linkLabel ?? 'Ver más'}
                            </p>
                        )}
                        <div class="mt-7 h-1 w-10 rounded-full bg-indigo-600/70 transition group-hover:w-16" />
                        {item.href && (
                            <a
                                href={item.href}
                                class="absolute inset-0 rounded-[1.5rem]"
                                aria-label={item.linkLabel ?? item.title}
                            />
                        )}
                    </article>
                ))
            }
        </div>
    </div>
</section>
