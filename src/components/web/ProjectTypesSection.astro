---
import type { WebLandingContent } from '@/data/web-landing';
import { webContainerClass, webLabelClass } from '@components/web/styles';

type Props = {
	projects: WebLandingContent['projects'];
};

const { projects } = Astro.props as Props;
---

<section id="projects" class="bg-white py-16 md:py-20">
	<div class={webContainerClass}>
		<div class="max-w-3xl">
			<p class={webLabelClass}>{projects.eyebrow}</p>
			<h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl">{projects.title}</h2>
			<p class="mt-5 text-base leading-relaxed text-slate-600">{projects.description}</p>
		</div>

		<div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
			{
				projects.items.map((item, index) => (
					<article class:list={[
						'group min-h-[18rem] rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5 transition hover:-translate-y-1 hover:border-indigo-200 hover:bg-white hover:shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]',
						index === 2 && 'lg:mt-10',
						index === 4 && 'lg:mt-6',
					]}>
						<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-indigo-600">{item.accent}</p>
						<h3 class="mt-8 text-xl font-semibold tracking-tight text-slate-950">{item.title}</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600">{item.description}</p>
						<div class="mt-7 h-1 w-10 rounded-full bg-indigo-600/70 transition group-hover:w-16"></div>
					</article>
				))
			}
		</div>
	</div>
</section>
