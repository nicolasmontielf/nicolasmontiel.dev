---
import type { WebLandingContent } from '@/data/web-landing';
import type { Locale } from '@/i18n/locales';
import BuildSection from '@components/web/BuildSection.astro';
import ContactSection from '@components/web/ContactSection.astro';
import CriteriaSection from '@components/web/CriteriaSection.astro';
import HeroSection from '@components/web/HeroSection.astro';
import LandingHeader from '@components/web/LandingHeader.astro';
import ProjectTypesSection from '@components/web/ProjectTypesSection.astro';
import ScopeSection from '@components/web/ScopeSection.astro';

type Props = {
	locale: Locale;
	content: WebLandingContent;
};

const { locale, content } = Astro.props as Props;
---

<div class="bg-white text-slate-700">
	<LandingHeader locale={locale} nav={content.nav} whatsappLink={content.links.whatsapp} ctaLabel={content.hero.primaryCtaLabel} />

	<main>
		<HeroSection hero={content.hero} links={content.links} />
		<ProjectTypesSection projects={content.projects} />
		<ScopeSection scope={content.scope} />
		<BuildSection build={content.build} />
		<CriteriaSection criteria={content.criteria} />
		<ContactSection locale={locale} contact={content.contact} whatsappLink={content.links.whatsapp} />
	</main>
</div>
