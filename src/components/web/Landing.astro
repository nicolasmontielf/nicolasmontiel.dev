---
import HeroVideo from '@/assets/hero.webm';
import HeroVideoPreview from '@/assets/hero-preview.webp';
import ContactSection from '@components/common/landing/ContactSection.astro';
import FeatureCard from '@components/common/landing/FeatureCard.astro';
import Footer from '@components/common/landing/Footer.astro';
import HeroSection from '@components/common/landing/HeroSection.astro';
import IconBadge from '@components/common/landing/IconBadge.astro';
import LandingButtonLink from '@components/common/landing/LandingButtonLink.astro';
import LandingNavbar from '@components/common/landing/LandingNavbar.astro';
import ProcessSteps from '@components/common/landing/ProcessSteps.astro';
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import SectionHeading from '@components/common/landing/SectionHeading.astro';
import { landingContainerClass } from '@components/common/landing/styles';
import { getCommercialWhatsappLink } from '@/i18n/links';
import { resolveLocale } from '@/i18n/locales';
import { getMessages } from '@/i18n/messages';
import { getAboutPath } from '@/i18n/routing';
import type { WebLandingIconName } from '@/types/landing/content';
import type { WebLandingProps } from '@/types/landing/props';
import {
    FolderOpen,
    Globe,
    MessageCircle,
    Search,
    Shield,
} from '@lucide/astro';

const { content } = Astro.props as WebLandingProps;
const locale = resolveLocale(Astro.locals.locale);
const aboutPath = getAboutPath(locale);
const whatsappLink = getCommercialWhatsappLink('web', locale);
const labels = getMessages(locale).landing;
const heroImageAltByLocale = {
    es: 'Vista previa de dashboard web',
    en: 'Website dashboard preview',
};
const challengeIconByName: Record<WebLandingIconName, any> = {
    globe: Globe,
    'folder-open': FolderOpen,
    search: Search,
    'message-circle': MessageCircle,
    shield: Shield,
    'building-2': Globe,
    megaphone: Globe,
    'book-open': Globe,
    'sliders-horizontal': Globe,
    'calendar-clock': Globe,
    'chart-column': Globe,
    handshake: Globe,
    'clipboard-list': Globe,
    palette: Globe,
    code: Globe,
    check: Globe,
    rocket: Globe,
};
---

<div class="bg-white text-slate-700">
    <LandingNavbar
        nav={content.nav}
        whatsappLink={whatsappLink}
        ctaLabel={content.hero.primaryCtaLabel}
        containerClass={landingContainerClass}
    />

    <main>
        <HeroSection
            badge={content.hero.badge}
            title={content.hero.title}
            description={content.hero.description}
            primaryCtaLabel={content.hero.primaryCtaLabel}
            secondaryCtaLabel={content.hero.secondaryCtaLabel}
            primaryCtaHref={whatsappLink}
            secondaryCtaHref="#solutions"
            heroVideo={HeroVideo}
            heroPoster={HeroVideoPreview.src}
            heroImageAlt={heroImageAltByLocale[locale]}
        />

        <section
            id="challenges"
            class="bg-white py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.challenges.eyebrow}
                    title={content.challenges.title}
                    description={content.challenges.description}
                />

                <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {
                        content.challenges.items.map((item) => {
                            const Icon = challengeIconByName[item.icon];

                            return (
                                <FeatureCard
                                    title={item.title}
                                    description={item.description}
                                    layout="stacked"
                                    hoverable={true}
                                    className="p-5"
                                >
                                    <IconBadge slot="icon">
                                        <Icon
                                            size={18}
                                            strokeWidth={1.9}
                                        />
                                    </IconBadge>
                                </FeatureCard>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section
            id="solutions"
            class="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.solutions.eyebrow}
                    title={content.solutions.title}
                    description={content.solutions.description}
                />

                <div
                    class="mt-10 overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-[0_24px_60px_-42px_rgba(15,23,42,0.24)]"
                >
                    <table class="hidden w-full border-collapse md:table">
                        <thead class="bg-slate-50">
                            <tr class="text-left">
                                <th
                                    class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"
                                >
                                    {content.solutions.columns.solution}
                                </th>
                                <th
                                    class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"
                                >
                                    {content.solutions.columns.objective}
                                </th>
                                <th
                                    class="px-6 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"
                                >
                                    {content.solutions.columns.outcome}
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            {
                                content.solutions.rows.map((row) => (
                                    <tr class="group transition hover:bg-slate-50/70">
                                        <td class="w-[24%] px-6 py-5 align-top">
                                            <p class="text-[15px] font-semibold leading-snug text-slate-950">
                                                {row.solution}
                                            </p>
                                            {row.href && (
                                                <LandingButtonLink
                                                    href={row.href}
                                                    variant="subtle"
                                                    className="mt-3 inline-flex text-xs"
                                                >
                                                    {row.hrefLabel ??
                                                        labels.viewMore}
                                                </LandingButtonLink>
                                            )}
                                        </td>
                                        <td class="w-[38%] px-6 py-5 align-top text-sm leading-relaxed text-slate-600">
                                            {row.objective}
                                        </td>
                                        <td class="w-[38%] px-6 py-5 align-top text-sm leading-relaxed text-slate-700">
                                            <p>{row.outcome}</p>
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>

                    <div class="grid gap-px bg-slate-200 md:hidden">
                        {
                            content.solutions.rows.map((row) => (
                                <article class="bg-white p-5">
                                    <h3 class="text-base font-semibold tracking-tight text-slate-950">
                                        {row.solution}
                                    </h3>
                                    {row.href && (
                                        <LandingButtonLink
                                            href={row.href}
                                            variant="subtle"
                                            className="mt-3 inline-flex text-xs"
                                        >
                                            {row.hrefLabel ?? labels.viewMore}
                                        </LandingButtonLink>
                                    )}
                                    <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
                                        {content.solutions.columns.objective}
                                    </p>
                                    <p class="mt-1 text-sm leading-relaxed text-slate-600">
                                        {row.objective}
                                    </p>
                                    <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-indigo-700">
                                        {content.solutions.columns.outcome}
                                    </p>
                                    <p class="mt-1 text-sm leading-relaxed text-slate-700">
                                        {row.outcome}
                                    </p>
                                </article>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <section
            id="process"
            class="bg-white py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.process.eyebrow}
                    title={content.process.title}
                    description={content.process.description}
                    maxWidthClass="max-w-2xl"
                    titleClass="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl"
                    descriptionClass="mt-4 text-base leading-relaxed text-slate-600"
                />

                <ProcessSteps steps={content.process.steps} />
            </div>
        </section>

        <SharedProfileSection
            profile={content.profile}
            aboutLink={aboutPath}
            containerClass={landingContainerClass}
            sectionId="profile"
            sectionClass="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)]"
        />

        <ContactSection
            contact={content.contact}
            whatsappLink={whatsappLink}
            containerClass={landingContainerClass}
            source="web"
            sectionClass="bg-white"
        />
    </main>

    <Footer />
</div>
