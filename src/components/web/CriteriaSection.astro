---
import type { WebLandingContent } from '@/data/web-landing';
import { webContainerClass } from '@components/web/styles';

type Props = {
    criteria: WebLandingContent['criteria'];
};

const { criteria } = Astro.props as Props;
---

<section
    id="criteria"
    class="border-y border-slate-200 bg-slate-50 py-16 md:py-20"
>
    <div
        class={`${webContainerClass} grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start`}
    >
        <div>
            <p
                class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600"
            >
                {criteria.eyebrow}
            </p>
            <h2
                class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl"
            >
                {criteria.title}
            </h2>
            <p class="mt-5 max-w-xl text-base leading-relaxed text-slate-600">
                {criteria.description}
            </p>
        </div>

        <div class="grid gap-4">
            {
                criteria.items.map((item, index) => (
                    <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]">
                        <div class="flex items-start gap-4">
                            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-indigo-600 text-sm font-bold text-white">
                                {index + 1}
                            </span>
                            <div>
                                <h3 class="text-lg font-semibold tracking-tight text-slate-950">
                                    {item.title}
                                </h3>
                                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                    {item.description}
                                </p>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
