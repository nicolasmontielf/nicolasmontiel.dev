---
import { DEFAULT_LOCALE } from '@/i18n/locales';
import type {
    HeroImageAltByLocale,
    WebHeroSectionProps,
} from '@/types/landing/props';
import {
    webContainerClass,
    webLabelClass,
    webPrimaryButtonClass,
    webSecondaryButtonClass,
} from '@components/web/styles';
import HeroVideo from '@/assets/hero.webm';
import HeroVideoPreview from '@/assets/hero-preview.webp';

const { hero, links } = Astro.props as WebHeroSectionProps;
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const heroImageAltByLocale: HeroImageAltByLocale = {
    es: 'Preview de dashboard web como referencia visual',
    en: 'Website dashboard preview as visual placeholder',
};
const heroImageAlt = heroImageAltByLocale[locale];
---

<section
    id="hero"
    class="overflow-hidden bg-[radial-gradient(circle_at_10%_20%,rgba(99,102,241,0.12),transparent_32%),linear-gradient(135deg,#ffffff_0%,#f8fafc_48%,#eef4ff_100%)] py-16 md:py-24"
>
    <div
        class={`${webContainerClass} grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(360px,460px)] lg:items-center`}
    >
        <div>
            <p class={webLabelClass}>{hero.badge}</p>
            <h1
                class="mt-6 max-w-3xl text-4xl font-bold tracking-tight text-slate-950 md:text-6xl md:leading-[1.02]"
            >
                {hero.title}
            </h1>
            <p
                class="mt-6 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg"
            >
                {hero.description}
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
                <a
                    href={links.whatsapp}
                    target="_blank"
                    rel="noreferrer"
                    class={webPrimaryButtonClass}
                    >{hero.primaryCtaLabel}</a
                >
                <a
                    href="#projects"
                    class={webSecondaryButtonClass}
                    >{hero.secondaryCtaLabel}</a
                >
            </div>

            <p
                class="mt-7 max-w-xl border-l-2 border-indigo-300 pl-4 text-sm leading-relaxed text-slate-500"
            >
                {hero.note}
            </p>
        </div>

        <div class="relative mx-auto w-full max-w-md">
            <div
                class="rounded-[1.75rem] border border-slate-200 p-4 shadow-[0_24px_70px_-45px_rgba(15,23,42,0.42)]"
            >
                <video
                    class="w-full rounded-[1.2rem] object-cover"
                    autoplay
                    loop
                    muted
                    playsinline
                    poster={HeroVideoPreview.src}
                >
                    <source src={HeroVideo} type="video/webm">
                </video>
            </div>
        </div>
    </div>
</section>
