---
import type { WebLandingContent } from '@/data/web-landing';
import { webContainerClass, webLabelClass, webPrimaryButtonClass, webSecondaryButtonClass } from '@components/web/styles';

type Props = {
	hero: WebLandingContent['hero'];
	links: WebLandingContent['links'];
};

const { hero, links } = Astro.props as Props;
---

<section id="hero" class="overflow-hidden bg-[radial-gradient(circle_at_10%_20%,rgba(99,102,241,0.12),transparent_32%),linear-gradient(135deg,#ffffff_0%,#f8fafc_48%,#eef4ff_100%)] py-16 md:py-24">
	<div class={`${webContainerClass} grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(360px,450px)] lg:items-center`}>
		<div>
			<p class={webLabelClass}>{hero.badge}</p>
			<h1 class="mt-6 max-w-3xl text-4xl font-bold tracking-tight text-slate-950 md:text-6xl md:leading-[1.02]">
				{hero.title}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg">
				{hero.description}
			</p>

			<div class="mt-8 flex flex-wrap gap-3">
				<a href={links.whatsapp} target="_blank" rel="noreferrer" class={webPrimaryButtonClass}>{hero.primaryCtaLabel}</a>
				<a href="#projects" class={webSecondaryButtonClass}>{hero.secondaryCtaLabel}</a>
			</div>

			<p class="mt-7 max-w-xl border-l-2 border-indigo-300 pl-4 text-sm leading-relaxed text-slate-500">{hero.note}</p>
		</div>

		<div class="relative mx-auto w-full max-w-md">
			<div class="absolute -left-8 top-10 h-40 w-40 rounded-full bg-indigo-200/45 blur-3xl"></div>
			<div class="absolute -right-10 bottom-8 h-44 w-44 rounded-full bg-indigo-200/40 blur-3xl"></div>
			<div class="relative rounded-[2rem] border border-white/80 bg-white/75 p-5 shadow-[0_28px_90px_-48px_rgba(15,23,42,0.45)] backdrop-blur">
				<div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-[0_18px_45px_-36px_rgba(15,23,42,0.28)]">
					<div class="flex items-center justify-between gap-4">
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-indigo-600">{hero.visualTitle}</p>
						<div class="flex gap-1.5">
							<span class="h-2.5 w-2.5 rounded-full bg-indigo-500"></span>
							<span class="h-2.5 w-2.5 rounded-full bg-slate-200"></span>
							<span class="h-2.5 w-2.5 rounded-full bg-slate-200"></span>
						</div>
					</div>
					<div class="mt-8 space-y-3">
						{
							hero.visualItems.map((item, index) => (
								<div class:list={[
									'rounded-2xl border p-4',
									index === 1 ? 'border-indigo-200 bg-indigo-50' : 'border-slate-200 bg-slate-50',
								]}>
									<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">{item.label}</p>
									<p class="mt-2 text-lg font-semibold tracking-tight text-slate-950">{item.value}</p>
								</div>
							))
						}
					</div>
				</div>
				<div class="mt-4 grid grid-cols-3 gap-3">
					<div class="h-20 rounded-2xl border border-slate-200 bg-white"></div>
					<div class="h-20 rounded-2xl border border-indigo-200 bg-indigo-50"></div>
					<div class="h-20 rounded-2xl border border-slate-200 bg-white"></div>
				</div>
			</div>
		</div>
	</div>
</section>
