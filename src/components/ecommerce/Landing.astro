---
import HeroVideo from '@/assets/hero-ecommerce.webm';
import HeroVideoPreview from '@/assets/hero-ecommerce-preview.webp';
import ContactSection from '@components/common/landing/ContactSection.astro';
import FeatureCard from '@components/common/landing/FeatureCard.astro';
import Footer from '@components/common/landing/Footer.astro';
import HeroSection from '@components/common/landing/HeroSection.astro';
import IconBadge from '@components/common/landing/IconBadge.astro';
import LandingNavbar from '@components/common/landing/LandingNavbar.astro';
import ProcessSteps from '@components/common/landing/ProcessSteps.astro';
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import SectionHeading from '@components/common/landing/SectionHeading.astro';
import { landingContainerClass } from '@components/common/landing/styles';
import EcommerceSolutionGroupCard from '@components/ecommerce/EcommerceSolutionGroupCard.astro';
import CalloutPanel from '@components/common/landing/CalloutPanel.astro';
import { getCommercialWhatsappLink } from '@/i18n/links';
import { resolveLocale } from '@/i18n/locales';
import { getMessages } from '@/i18n/messages';
import { getAboutPath } from '@/i18n/routing';
import type { EcommerceLandingIconName } from '@/types/landing/content';
import type { EcommerceLandingProps } from '@/types/landing/props';
import {
    CreditCard,
    MessageCircle,
    Package,
    Search,
    Smartphone,
} from '@lucide/astro';

const { content } = Astro.props as EcommerceLandingProps;
const locale = resolveLocale(Astro.locals.locale);
const aboutPath = getAboutPath(locale);
const whatsappLink = getCommercialWhatsappLink('ecommerce', locale);
const labels = getMessages(locale).landing;
const heroImageAltByLocale = {
    es: 'Vista previa de storefront ecommerce',
    en: 'Ecommerce storefront preview',
};
const challengeIconByName: Record<EcommerceLandingIconName, any> = {
    'message-circle': MessageCircle,
    search: Search,
    package: Package,
    smartphone: Smartphone,
    'credit-card': CreditCard,
    'layout-grid': Package,
    'shopping-bag': Package,
    'shopping-cart': Package,
    wallet: CreditCard,
    boxes: Package,
    truck: Package,
};
---

<div class="bg-white text-slate-700">
    <LandingNavbar
        nav={content.nav}
        whatsappLink={whatsappLink}
        ctaLabel={content.hero.primaryCtaLabel}
        containerClass={landingContainerClass}
    />

    <main>
        <HeroSection
            badge={content.hero.badge}
            title={content.hero.title}
            description={content.hero.description}
            primaryCtaLabel={content.hero.primaryCtaLabel}
            secondaryCtaLabel={content.hero.secondaryCtaLabel}
            primaryCtaHref={whatsappLink}
            secondaryCtaHref="#challenges"
            heroVideo={HeroVideo}
            heroPoster={HeroVideoPreview.src}
            heroImageAlt={heroImageAltByLocale[locale]}
        />

        <section
            id="challenges"
            class="bg-white py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.challenges.eyebrow}
                    title={content.challenges.title}
                    description={content.challenges.description}
                />

                <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {
                        content.challenges.items.map((item) => {
                            const Icon = challengeIconByName[item.icon];

                            return (
                                <FeatureCard
                                    title={item.title}
                                    description={item.description}
                                    layout="stacked"
                                    hoverable={true}
                                    className="p-5"
                                >
                                    <IconBadge slot="icon">
                                        <Icon
                                            size={18}
                                            strokeWidth={1.9}
                                        />
                                    </IconBadge>
                                </FeatureCard>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section
            id="solutions"
            class="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.solutions.eyebrow}
                    title={content.solutions.title}
                    description={content.solutions.description}
                />

                <div class="mt-10 grid gap-5 lg:grid-cols-3">
                    {
                        content.solutions.groups.map((group) => (
                            <EcommerceSolutionGroupCard
                                title={group.title}
                                subtitle={group.subtitle}
                                items={group.items}
                            />
                        ))
                    }
                </div>

                {
                    content.solutions.bridgeToWeb && (
                        <CalloutPanel
                            eyebrow={labels.alternative}
                            title={content.solutions.bridgeToWeb.title}
                            description={
                                content.solutions.bridgeToWeb.description
                            }
                            ctaHref={content.solutions.bridgeToWeb.href}
                            ctaLabel={content.solutions.bridgeToWeb.ctaLabel}
                            tone="primary"
                            className="mt-8 rounded-[1.4rem]"
                        />
                    )
                }
            </div>
        </section>

        <section
            id="process"
            class="bg-white py-16 md:py-20"
        >
            <div class={landingContainerClass}>
                <SectionHeading
                    eyebrow={content.process.eyebrow}
                    title={content.process.title}
                    description={content.process.description}
                    maxWidthClass="max-w-2xl"
                    titleClass="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl"
                    descriptionClass="mt-4 text-base leading-relaxed text-slate-600"
                />

                <ProcessSteps steps={content.process.steps} />
            </div>
        </section>

        <SharedProfileSection
            profile={content.profile}
            aboutLink={aboutPath}
            containerClass={landingContainerClass}
            sectionId="profile"
            sectionClass="bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)]"
        />

        <ContactSection
            contact={content.contact}
            whatsappLink={whatsappLink}
            containerClass={landingContainerClass}
            source="ecommerce"
            sectionClass="bg-white"
        />
    </main>

    <Footer />
</div>
