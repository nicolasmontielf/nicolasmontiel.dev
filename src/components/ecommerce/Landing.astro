---
import type { EcommerceLandingContent } from '@/data/ecommerce-landing';
import type { Locale } from '@/i18n/locales';

type Props = {
	locale: Locale;
	content: EcommerceLandingContent;
};

const { locale, content } = Astro.props as Props;
const sectionContainerClass = 'mx-auto w-full max-w-screen-lg px-3 lg:px-0';

const defaultWhyHighlights = content.whyEcommerce.scenarios.map((scenario) => ({
	label: scenario.title,
	accent: 'Estrategia ecommerce',
}));

const heroMockup =
	content.visuals?.heroMockup ?? {
		title: 'Ecommerce con foco en negocio y continuidad',
		tags: ['Lanzamiento', 'Optimización', 'Soporte'],
		steps: [
			{ label: 'Objetivo', value: 'Vender online con estabilidad' },
			{ label: 'Ejecución', value: 'Roadmap + entregables claros' },
			{ label: 'Soporte', value: 'Mejora continua con datos' },
		],
		supportTitle: 'Acompañamiento continuo',
		supportDescription: 'Seguimiento técnico y funcional después del go-live.',
	};

const whyHighlights = content.visuals?.whyHighlights ?? defaultWhyHighlights;
const heroBadgeEmoji = content.visuals?.emojis?.heroBadge;
const whyTitleEmoji = content.visuals?.emojis?.whyTitle;
const ctaTitleEmoji = content.visuals?.emojis?.ctaTitle;
const labels = locale === 'es'
	? {
			visualBrief: 'Resumen visual',
			stepPrefix: 'Paso',
			service: 'Servicio',
		}
	: {
			visualBrief: 'Visual brief',
			stepPrefix: 'Step',
			service: 'Service',
		};
---

<div class="relative overflow-hidden">
	<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(99,102,241,0.14),_transparent_48%),radial-gradient(circle_at_bottom_left,_rgba(59,130,246,0.08),_transparent_40%)]"></div>

	<div class="relative">
		<header class="sticky top-0 z-20 border-y border-slate-200/90 bg-slate-50/90 backdrop-blur">
			<nav class={`flex items-center gap-3 overflow-x-auto py-4 text-sm font-semibold text-slate-700 ${sectionContainerClass}`}>
				{
					content.nav.items.map((item) => (
						<a
							href={`#${item.id}`}
							class="shrink-0 rounded-full border border-slate-300 px-4 py-2 transition hover:border-indigo-400 hover:text-indigo-700"
						>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>

		<section id="hero" class="pb-12 pt-10 md:pb-16 md:pt-16">
			<div class={`${sectionContainerClass} grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center`}>
				<div>
					<p class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-indigo-50 px-3 py-1 text-xs font-semibold tracking-wide text-indigo-700">
						{heroBadgeEmoji && <span aria-hidden="true">{heroBadgeEmoji}</span>}
						<span>{content.hero.badge}</span>
					</p>

					<h1 class="mt-5 max-w-4xl text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
						{content.hero.title}
					</h1>

					<p class="mt-5 max-w-3xl text-lg leading-relaxed text-slate-700">
						{content.hero.description}
					</p>

					<div class="mt-7 flex flex-wrap items-center gap-3">
						<a
							href={content.links.whatsapp}
							target="_blank"
							rel="noreferrer"
							class="rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
						>
							{content.hero.primaryCtaLabel}
						</a>
						<a
							href={content.links.about}
							class="rounded-xl border border-indigo-200 bg-white px-5 py-3 text-sm font-semibold text-indigo-700 transition hover:border-indigo-400 hover:text-indigo-800"
						>
							{content.hero.secondaryCtaLabel}
						</a>
					</div>

					<p class="mt-5 text-sm font-medium text-slate-600">{content.hero.trustNote}</p>
				</div>

				<aside class="border border-slate-200 bg-white p-5 shadow-[0_16px_32px_-24px_rgba(15,23,42,0.7)] md:p-6">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-indigo-500">{labels.visualBrief}</p>
					<h3 class="mt-3 text-xl font-semibold text-slate-900">{heroMockup.title}</h3>

					<div class="mt-4 flex flex-wrap gap-2">
						{
							heroMockup.tags.map((tag) => (
								<span class="rounded-full border border-indigo-200 bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700">{tag}</span>
							))
						}
					</div>

					<div class="mt-5 space-y-3">
						{
							heroMockup.steps.map((step, index) => (
								<div class="border border-slate-200 bg-slate-50 p-3">
									<p class="text-xs font-semibold text-indigo-600">{labels.stepPrefix} {index + 1} · {step.label}</p>
									<p class="mt-1 text-sm text-slate-700">{step.value}</p>
								</div>
							))
						}
					</div>

					<div class="mt-5 border-l-2 border-indigo-400 bg-indigo-50/60 p-4">
						<p class="text-sm font-semibold text-slate-900">{heroMockup.supportTitle}</p>
						<p class="mt-1 text-sm text-slate-700">{heroMockup.supportDescription}</p>
					</div>
				</aside>
			</div>
		</section>

		<section id="why" class="border-t border-slate-200 py-12 md:py-14">
			<div class={sectionContainerClass}>
				<h2 class="max-w-4xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
					{whyTitleEmoji && <span aria-hidden="true" class="mr-2">{whyTitleEmoji}</span>}
					{content.whyEcommerce.title}
				</h2>
				<p class="mt-4 max-w-3xl text-slate-700">{content.whyEcommerce.description}</p>

				<div class="mt-7 grid gap-4 md:grid-cols-3">
					{
						content.whyEcommerce.scenarios.map((scenario, index) => (
							<article class="border border-slate-200 bg-white p-5 shadow-[0_12px_24px_-20px_rgba(15,23,42,0.6)]">
								<div class="flex items-center justify-between gap-3">
									<span class="text-xs font-semibold uppercase tracking-[0.14em] text-indigo-500">
										{whyHighlights[index]?.label ?? 'Ecommerce'}
									</span>
									<span class="text-[11px] font-medium text-slate-500">{whyHighlights[index]?.accent ?? ''}</span>
								</div>
								<div class="my-4 h-[2px] w-12 bg-indigo-400"></div>
								<h3 class="text-lg font-semibold text-slate-900">{scenario.title}</h3>
								<p class="mt-2 text-slate-700">{scenario.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="services" class="border-t border-slate-200 py-12 md:py-14">
			<div class={sectionContainerClass}>
				<h2 class="max-w-4xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{content.services.title}</h2>
				<p class="mt-4 max-w-3xl text-slate-700">{content.services.description}</p>

				<div class="mt-7 grid gap-4 md:grid-cols-2">
					{
						content.services.items.map((service) => (
							<article class="border border-slate-200 bg-white p-6 transition hover:border-indigo-300 hover:shadow-[0_14px_28px_-22px_rgba(79,70,229,0.85)]">
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-500">{labels.service}</p>
								<h3 class="mt-3 text-xl font-semibold text-slate-900">{service.title}</h3>
								<p class="mt-3 text-slate-700">{service.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="process" class="border-t border-slate-200 py-12 md:py-14">
			<div class={sectionContainerClass}>
				<h2 class="max-w-4xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{content.process.title}</h2>
				<p class="mt-4 max-w-3xl text-slate-700">{content.process.description}</p>

				<ol class="mt-7 grid gap-4 md:grid-cols-3">
					{
						content.process.steps.map((step) => (
							<li class="border border-slate-200 bg-gradient-to-b from-indigo-50/60 to-white p-5">
								<h3 class="text-base font-semibold text-indigo-700">{step.title}</h3>
								<p class="mt-2 text-slate-700">{step.description}</p>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<section id="cta" class="border-t border-slate-200 py-12 md:py-16">
			<div class={sectionContainerClass}>
				<div class="bg-gradient-to-r from-indigo-700 via-indigo-700 to-slate-900 p-7 text-white md:p-10">
					<h2 class="max-w-3xl text-2xl font-bold tracking-tight md:text-4xl">
						{ctaTitleEmoji && <span aria-hidden="true" class="mr-2">{ctaTitleEmoji}</span>}
						{content.cta.title}
					</h2>
					<p class="mt-4 max-w-2xl text-sm text-indigo-100 md:text-base">{content.cta.description}</p>
					<a
						href={content.links.whatsapp}
						target="_blank"
						rel="noreferrer"
						class="mt-6 inline-flex rounded-xl bg-white px-5 py-3 text-sm font-semibold text-indigo-700 transition hover:bg-indigo-50"
					>
						{content.cta.primaryButtonLabel}
					</a>
				</div>
			</div>
		</section>
	</div>
</div>
