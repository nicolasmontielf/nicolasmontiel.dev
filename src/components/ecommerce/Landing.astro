---
import type { EcommerceLandingContent } from '@/data/ecommerce-landing';
import type { Locale } from '@/i18n/locales';

type Props = {
	locale: Locale;
	content: EcommerceLandingContent;
};

const { locale, content } = Astro.props as Props;
const sectionContainerClass = 'mx-auto w-full max-w-screen-lg px-3 lg:px-0';
const sectionLabelClass = 'text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600';
---

<div class="relative overflow-hidden bg-slate-50">
	<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(99,102,241,0.12),_transparent_42%),radial-gradient(circle_at_bottom_right,_rgba(15,23,42,0.08),_transparent_36%)]"></div>
	<div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-indigo-300/80 to-transparent"></div>

	<header class="sticky top-0 z-20 border-b border-slate-200/90 bg-slate-50/85 backdrop-blur">
		<div class={`flex items-center justify-between gap-6 py-4 ${sectionContainerClass}`}>
			<a href={`/${locale}`} class="flex items-center gap-3 text-slate-900">
				<span class="text-base font-bold tracking-tight">Nicolás Montiel</span>
				<span class="hidden h-4 w-px bg-slate-300 md:block"></span>
				<span class="hidden text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 md:block">{content.nav.label}</span>
			</a>

			<nav class="hidden items-center gap-5 text-sm font-medium text-slate-600 md:flex">
				{
					content.nav.items.map((item) => (
						<a href={`#${item.id}`} class="transition-colors hover:text-indigo-700">
							{item.label}
						</a>
					))
				}
			</nav>
		</div>
	</header>

	<div class="relative">
		<section id="hero" class="pb-14 pt-12 md:pb-20 md:pt-16">
			<div class={`${sectionContainerClass} grid gap-8 lg:grid-cols-[minmax(0,1.12fr)_minmax(320px,0.88fr)]`}>
				<div>
					<p class="inline-flex items-center rounded-full border border-indigo-200 bg-white px-3 py-1 text-xs font-semibold tracking-[0.18em] text-indigo-700 shadow-sm">
						{content.hero.badge}
					</p>

					<h1 class="mt-6 max-w-4xl text-balance text-4xl font-bold tracking-tight text-slate-950 md:text-6xl">
						{content.hero.title}
					</h1>

					<p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-700 md:text-xl">
						{content.hero.description}
					</p>

					<div class="mt-8 flex flex-wrap items-center gap-3">
						<a
							href={content.links.whatsapp}
							target="_blank"
							rel="noreferrer"
							class="rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
						>
							{content.hero.primaryCtaLabel}
						</a>
						<a
							href={content.links.about}
							class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-indigo-300 hover:text-indigo-700"
						>
							{content.hero.secondaryCtaLabel}
						</a>
					</div>

                    <hr class="mt-6 border-slate-200" />
				</div>

				<div class="p-2 lg:p-12">
					<img
                        src="/storefront-preview.png"
                        class="w-auto max-h-[800px] mx-auto md:max-h-auto"
                        alt="Image showing an ecommerce storefront"
                    />
				</div>
			</div>

			<div class={`${sectionContainerClass} mt-6 grid gap-4 lg:mt-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]`}>
				<article class="border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.45)]">
						<p class={sectionLabelClass}>{content.hero.fitEyebrow}</p>
						<h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">{content.hero.fitTitle}</h2>

						<ul class="mt-5 space-y-3">
							{
								content.hero.fitItems.map((item) => (
									<li class="flex gap-3 text-sm leading-relaxed text-slate-700">
										<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-indigo-500"></span>
										<span>{item}</span>
									</li>
								))
							}
						</ul>
				</article>

				<article class="overflow-hidden rounded-[1.5rem] bg-slate-900 p-6 text-slate-50 shadow-[0_22px_48px_-30px_rgba(15,23,42,0.9)]">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-200">{content.hero.commitmentsEyebrow}</p>
					<h2 class="mt-3 text-2xl font-semibold tracking-tight">{content.hero.commitmentsTitle}</h2>

					<div class="mt-6 grid gap-4">
						{
							content.hero.commitments.map((item) => (
								<div class="border-t border-white/10 pt-4 first:border-t-0 first:pt-0">
									<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-indigo-200">{item.label}</p>
									<p class="mt-2 text-sm leading-relaxed text-slate-200">{item.value}</p>
								</div>
							))
						}
					</div>
				</article>
				</div>
		</section>

		<section id="situations" class="border-t border-slate-200 py-14 md:py-16">
			<div class={`${sectionContainerClass} grid gap-10 lg:grid-cols-[0.78fr_1.22fr]`}>
				<div class="lg:sticky lg:top-24 lg:self-start">
					<p class={sectionLabelClass}>{content.situations.eyebrow}</p>
					<h2 class="mt-3 max-w-xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
						{content.situations.title}
					</h2>
					<p class="mt-4 max-w-lg leading-relaxed text-slate-700">{content.situations.description}</p>

					<div class="mt-8 border-l-2 border-indigo-300 pl-5">
						<p class="text-sm font-semibold text-slate-900">{content.situations.leadTitle}</p>
						<p class="mt-2 text-sm leading-relaxed text-slate-600">{content.situations.leadDescription}</p>
					</div>
				</div>

				<div class="grid gap-4 md:grid-cols-2">
					{
						content.situations.scenarios.map((scenario, index) => (
							<article
								class:list={[
									'border border-slate-200 bg-white p-6 shadow-[0_16px_36px_-30px_rgba(15,23,42,0.45)]',
									index === 0 && 'md:col-span-2 md:grid md:grid-cols-[0.42fr_0.58fr] md:items-start md:gap-6',
								]}
							>
								<div>
									<p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">{scenario.kicker}</p>
									<h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900 md:text-2xl">
										{scenario.title}
									</h3>
								</div>

								<p class:list={['mt-4 leading-relaxed text-slate-700', index === 0 && 'md:mt-0']}>
									{scenario.description}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="work" class="border-t border-slate-200 py-14 md:py-16">
			<div class={`${sectionContainerClass} grid gap-10 lg:grid-cols-[0.86fr_1.14fr]`}>
				<div>
					<p class={sectionLabelClass}>{content.work.eyebrow}</p>
					<h2 class="mt-3 max-w-xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{content.work.title}</h2>
					<p class="mt-4 max-w-lg leading-relaxed text-slate-700">{content.work.description}</p>

					<div class="mt-8 border border-slate-200 bg-white p-5 shadow-[0_18px_36px_-30px_rgba(15,23,42,0.4)]">
						<p class="text-sm font-semibold text-slate-900">{content.work.noteTitle}</p>
						<p class="mt-2 text-sm leading-relaxed text-slate-600">{content.work.noteDescription}</p>
					</div>

					<div>
                        <img
                            src="/dashboard-preview.png"
                            class="w-auto max-h-[500px] mx-auto mt-8 md:max-h-auto shadow-md border"
                            alt="Image showing a collage of three product screenshots: catalog or listing page, product detail page, and checkout or a key purchase step."
                        />
                    </div>
				</div>

				<div class="border-y border-slate-200 py-5">
					{
						content.work.items.map((item) => (
							<article class="grid gap-5 py-6 first:pt-0 last:pb-0 md:grid-cols-[0.34fr_0.66fr] md:items-start">
								<div>
									<p class="text-lg font-semibold tracking-tight text-slate-900">{item.title}</p>
								</div>

								<div>
									<p class="leading-relaxed text-slate-700">{item.description}</p>

									<div class="mt-4 flex flex-wrap gap-2">
										{
											item.examples.map((example) => (
												<span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-700">
													{example}
												</span>
											))
										}
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="process" class="border-t border-slate-200 py-14 md:py-16">
			<div class={`${sectionContainerClass} grid gap-10 lg:grid-cols-[0.9fr_1.1fr]`}>
				<div>
					<p class={sectionLabelClass}>{content.process.eyebrow}</p>
					<h2 class="mt-3 max-w-xl text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{content.process.title}</h2>
					<p class="mt-4 max-w-lg leading-relaxed text-slate-700">{content.process.description}</p>

					<div class="mt-8 space-y-5">
						{
							content.process.principles.map((principle) => (
								<div class="border-l-2 border-indigo-300 pl-5">
									<p class="text-sm font-semibold text-slate-900">{principle.title}</p>
									<p class="mt-2 text-sm leading-relaxed text-slate-600">{principle.description}</p>
								</div>
							))
						}
					</div>
				</div>

				<ol class="space-y-4">
					{
						content.process.steps.map((step, index) => (
							<li class="grid gap-4 border border-slate-200 bg-white p-5 shadow-[0_16px_36px_-30px_rgba(15,23,42,0.35)] md:grid-cols-[56px_1fr] md:items-start">
								<div class="flex h-14 w-14 items-center justify-center rounded-full border border-indigo-200 bg-indigo-50 text-sm font-semibold text-indigo-700">
									{index + 1}
								</div>

								<div>
									<h3 class="text-lg font-semibold tracking-tight text-slate-900">{step.title}</h3>
									<p class="mt-2 leading-relaxed text-slate-700">{step.description}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<section id="cta" class="border-t border-slate-200 py-14 md:py-18">
			<div class={sectionContainerClass}>
				<div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_24px_60px_-34px_rgba(15,23,42,0.55)]">
					<div class="grid lg:grid-cols-[1.08fr_0.92fr]">
						<div class="bg-[linear-gradient(180deg,#ffffff_0%,#eef2ff_100%)] p-7 md:p-10">
							<p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700">{content.cta.eyebrow}</p>
							<h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">{content.cta.title}</h2>
							<p class="mt-4 leading-relaxed text-slate-700 md:text-lg">{content.cta.description}</p>
						</div>

						<div class="flex flex-col gap-4 bg-slate-950 p-7 text-white md:p-10">
							<p class="text-sm leading-relaxed text-slate-200">{content.cta.supportNote}</p>
							<div class="flex flex-wrap gap-3">
								<a
									href={content.links.whatsapp}
									target="_blank"
									rel="noreferrer"
									class="rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100"
								>
									{content.cta.primaryButtonLabel}
								</a>
								<a
									href={content.links.about}
									class="rounded-xl border border-white/20 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/40 hover:bg-white/5"
								>
									{content.cta.secondaryButtonLabel}
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</div>
