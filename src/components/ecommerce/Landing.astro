---
import type { EcommerceLandingContent } from '@/data/ecommerce-landing';
import type { Locale } from '@/i18n/locales';
import ServiceIcon from '@components/ecommerce/ServiceIcon.astro';

type Props = {
	locale: Locale;
	content: EcommerceLandingContent;
};

const { locale, content } = Astro.props as Props;
const sectionContainerClass = 'mx-auto w-full max-w-[1120px] px-4 sm:px-6 lg:px-8';
const sectionLabelClass = 'text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600';
const contactFormId = `contact-form-${locale}`;
const contactStatusId = `contact-status-${locale}`;
const avatarSrc = '/nicolas-montiel-avatar.png';
const heroImageSrc = '/storefront-preview.png';
const featuredWorkItem = content.work.items[0];
const secondaryWorkItems = content.work.items.slice(1);
---

<div class="bg-white text-slate-700">
	<header class="border-b border-slate-200 bg-white/95 backdrop-blur">
		<div class={`flex items-center justify-between gap-6 py-5 ${sectionContainerClass}`}>
			<a href={`/${locale}`} class="flex items-center gap-3 text-slate-900">
				<span class="text-[11px] font-semibold uppercase tracking-[0.26em] text-indigo-600">Nicolas Montiel</span>
				<span class="hidden text-[11px] uppercase tracking-[0.22em] text-slate-400 md:block">{content.nav.label}</span>
			</a>

			<nav class="hidden items-center gap-6 text-sm text-slate-500 md:flex">
				{
					content.nav.items.map((item) => (
						<a href={`#${item.id}`} class="transition-colors hover:text-slate-900">
							{item.label}
						</a>
					))
				}
			</nav>

			<a
				href={content.links.whatsapp}
				target="_blank"
				rel="noreferrer"
				class="rounded-md bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-700"
			>
				{content.hero.primaryCtaLabel}
			</a>
		</div>
	</header>

	<main>
		<section id="hero" class="bg-white py-14 md:py-20">
			<div class={`${sectionContainerClass} grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(360px,460px)] lg:items-center`}>
				<div>
					<p class={sectionLabelClass}>{content.hero.badge}</p>
					<h1 class="mt-6 max-w-2xl text-4xl font-bold tracking-tight text-slate-950 md:text-6xl md:leading-[1.02]">
						{content.hero.title}
					</h1>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 md:text-lg">
						{content.hero.description}
					</p>

					<div class="mt-8 flex flex-wrap gap-3">
						<a
							href={content.links.whatsapp}
							target="_blank"
							rel="noreferrer"
							class="rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
						>
							{content.hero.primaryCtaLabel}
						</a>
						<a
							href={content.links.about}
							class="rounded-md border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900"
						>
							{content.hero.secondaryCtaLabel}
						</a>
					</div>

					<p class="mt-6 max-w-xl text-sm leading-relaxed text-slate-500">{content.hero.trustNote}</p>
				</div>

				<div class="relative">
					<img src={heroImageSrc} class="max-h-[45rem]">

					<div class="absolute -bottom-5 left-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-[0_16px_40px_-30px_rgba(15,23,42,0.4)]">
						<p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">{content.hero.floatingCardLabel}</p>
						<p class="mt-1 text-sm font-medium text-slate-900">{content.hero.floatingCardValue}</p>
					</div>
				</div>
			</div>
		</section>

		<section id="work" class="border-y border-slate-200 bg-slate-50 py-16 md:py-20">
			<div class={`${sectionContainerClass}`}>
				<div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-start">
					<div class="grid gap-5 md:grid-cols-2">
						{
							secondaryWorkItems.map((item) => (
								<article
									class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]"
								>
									<ServiceIcon name={item.icon} />
									<h3 class="mt-5 text-lg font-semibold tracking-tight text-slate-900">{item.title}</h3>
									<p class="mt-3 text-sm leading-relaxed text-slate-600">{item.description}</p>
								</article>
							))
						}
					</div>

					<div>
						<p class={sectionLabelClass}>{content.work.eyebrow}</p>
						<h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-5xl">
							{content.work.title}
						</h2>
						<p class="mt-5 text-base leading-relaxed text-slate-600">{content.work.description}</p>

						<div class="flex items-start gap-4">
							<div>
								<!-- <p class="text-lg font-semibold tracking-tight text-slate-950">{featuredWorkItem.title}</p> -->
								<p class="mt-3 text-sm leading-relaxed text-slate-600">{featuredWorkItem.description}</p>
							</div>
						</div>

						<div class="mt-8 h-px bg-slate-200"></div>

						<p class="mt-8 text-sm font-semibold tracking-tight text-slate-950">{content.work.noteTitle}</p>
						<p class="mt-3 text-sm leading-relaxed text-slate-600">{content.work.noteDescription}</p>
					</div>
				</div>
			</div>
		</section>

		<section id="profile" class="bg-white py-16 md:py-20">
			<div class={`${sectionContainerClass} grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start`}>
				<div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.22)]">
					<div class="flex items-center gap-4">
						<img src={avatarSrc} alt="Avatar de Nicolás Montiel" class="h-14 w-14 rounded-full border border-slate-200 object-cover" loading="lazy" />
						<div>
							<p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600">{content.profile.eyebrow}</p>
							<p class="mt-1 text-sm font-medium text-slate-500">Nicolás Montiel</p>
						</div>
					</div>

					<h2 class="mt-6 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">{content.profile.title}</h2>
					<p class="mt-4 leading-relaxed text-slate-600">{content.profile.description}</p>
					<a
						href={content.links.about}
						class="mt-8 inline-flex rounded-md border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-300 hover:bg-slate-100"
					>
						{content.profile.buttonLabel}
					</a>
				</div>

				<div class="grid gap-5">
					{
						content.profile.items.map((item) => (
							<article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.16)]">
								<h3 class="text-lg font-semibold tracking-tight text-slate-900">{item.title}</h3>
								<p class="mt-3 text-sm leading-relaxed text-slate-600">{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="process" class="border-y border-slate-200 bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20">
			<div class={`${sectionContainerClass}`}>
				<div class="max-w-2xl">
					<p class={sectionLabelClass}>{content.process.eyebrow}</p>
					<h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">{content.process.title}</h2>
					<p class="mt-4 text-base leading-relaxed text-slate-600">{content.process.description}</p>
				</div>

				<ol class="relative mt-12 grid gap-5 md:grid-cols-2">
					<div class="pointer-events-none absolute left-6 top-6 hidden h-[calc(100%-3rem)] w-px bg-gradient-to-b from-indigo-200 via-indigo-100 to-transparent md:block"></div>
					{
						content.process.steps.map((step, index) => (
							<li class:list={[
								'relative rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-[0_20px_45px_-34px_rgba(15,23,42,0.18)]',
								index % 2 === 1 && 'md:translate-y-10',
							]}>
								<div class="flex items-start gap-4">
									<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-indigo-600 text-sm font-semibold text-white shadow-[0_12px_30px_-18px_rgba(79,70,229,0.9)]">
										{index + 1}
									</div>
									<div>
										<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">Paso {index + 1}</p>
										<h3 class="mt-2 text-xl font-semibold tracking-tight text-slate-950">{step.title}</h3>
										<p class="mt-3 text-sm leading-relaxed text-slate-600">{step.description}</p>
									</div>
								</div>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<section id="contact" class="bg-white py-16 md:py-20">
			<div class={`${sectionContainerClass} grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start`}>
				<div>
					<p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-indigo-600">{content.contact.eyebrow}</p>
					<h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">{content.contact.title}</h2>
					<p class="mt-4 max-w-xl text-base leading-relaxed text-slate-600">{content.contact.description}</p>

					<div class="mt-8 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.15)]">
						<p class="text-sm leading-relaxed text-slate-600">{content.contact.whatsappNote}</p>
						<a
							href={content.links.whatsapp}
							target="_blank"
							rel="noreferrer"
							class="mt-5 inline-flex rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
						>
							{content.contact.whatsappCtaLabel}
						</a>
					</div>
				</div>

				<div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-[0_24px_60px_-40px_rgba(15,23,42,0.15)] md:p-8">
					<p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-500">{content.contact.formTitle}</p>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">{content.contact.formDescription}</p>

					<form
						id={contactFormId}
						class="mt-6 space-y-4"
						data-contact-form
						data-name-required-message={content.contact.nameRequiredMessage}
						data-contact-required-message={content.contact.contactRequiredMessage}
						data-not-configured-message={content.contact.notConfiguredMessage}
						data-error-message={content.contact.errorMessage}
						data-submitting-label={content.contact.submittingLabel}
						data-submit-label={content.contact.submitLabel}
					>
						<div>
							<label for={`${contactFormId}-name`} class="block text-sm font-medium text-slate-700">{content.contact.nameLabel}</label>
							<input
								id={`${contactFormId}-name`}
								name="name"
								type="text"
								class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-400 focus:outline-none"
								placeholder={content.contact.namePlaceholder}
								required
							/>
						</div>

						<div>
							<label for={`${contactFormId}-email`} class="block text-sm font-medium text-slate-700">{content.contact.emailLabel}</label>
							<input
								id={`${contactFormId}-email`}
								name="email"
								type="email"
								class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-400 focus:outline-none"
								placeholder={content.contact.emailPlaceholder}
							/>
						</div>

						<div>
							<label for={`${contactFormId}-whatsapp`} class="block text-sm font-medium text-slate-700">{content.contact.whatsappLabel}</label>
							<input
								id={`${contactFormId}-whatsapp`}
								name="whatsapp"
								type="tel"
								class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-400 focus:outline-none"
								placeholder={content.contact.whatsappPlaceholder}
							/>
						</div>

						<p class="text-xs leading-relaxed text-slate-500">{content.contact.helperText}</p>

						<p id={contactStatusId} class="hidden rounded-lg border px-4 py-3 text-sm" aria-live="polite"></p>

						<button
							type="submit"
							class="w-full rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700 disabled:cursor-not-allowed disabled:bg-indigo-500/70"
						>
							{content.contact.submitLabel}
						</button>
					</form>
				</div>
			</div>
		</section>
	</main>
</div>

<script is:inline>
	const forms = document.querySelectorAll('[data-contact-form]');

	for (const form of forms) {
		const status = form.querySelector('[aria-live]') || document.getElementById(form.id.replace('contact-form', 'contact-status'));
		const submitButton = form.querySelector('button[type="submit"]');
		const defaultSubmitLabel = form.dataset.submitLabel || (submitButton ? submitButton.textContent : 'Submit');

		const setStatus = (message, tone) => {
			if (!status) return;
			status.textContent = message;
			status.className = 'rounded-lg border px-4 py-3 text-sm';
			if (tone === 'error') {
				status.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
			} else if (tone === 'warning') {
				status.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-700');
			} else {
				status.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-700');
			}
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			const formData = new FormData(form);
			const name = String(formData.get('name') || '').trim();
			const email = String(formData.get('email') || '').trim();
			const whatsapp = String(formData.get('whatsapp') || '').trim();

			if (status) {
				status.textContent = '';
				status.className = 'hidden rounded-lg border px-4 py-3 text-sm';
			}

			if (!name) {
				setStatus(form.dataset.nameRequiredMessage || 'Name is required.', 'error');
				return;
			}

			if (!email && !whatsapp) {
				setStatus(form.dataset.contactRequiredMessage || 'Email or WhatsApp is required.', 'error');
				return;
			}

			if (submitButton) {
				submitButton.disabled = true;
				submitButton.textContent = form.dataset.submittingLabel || 'Sending...';
			}

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify({ name, email, whatsapp }),
				});

				const payload = await response.json().catch(() => null);

				if (!response.ok) {
					if (payload && payload.code === 'NOT_CONFIGURED') {
						setStatus(payload.message || form.dataset.notConfiguredMessage || 'Not configured yet.', 'warning');
					} else {
						setStatus((payload && payload.message) || form.dataset.errorMessage || 'Unexpected error.', 'error');
					}
					return;
				}

				setStatus((payload && payload.message) || 'Message sent.', 'success');
				form.reset();
			} catch (_error) {
				setStatus(form.dataset.errorMessage || 'Unexpected error.', 'error');
			} finally {
				if (submitButton) {
					submitButton.disabled = false;
					submitButton.textContent = defaultSubmitLabel;
				}
			}
		});
	}
</script>
