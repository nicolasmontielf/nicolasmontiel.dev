---
import HeroVideo from '@/assets/hero-ecommerce.webm';
import HeroVideoPreview from '@/assets/hero-ecommerce-preview.webp';
import CommercialLanding from '@components/common/landing/CommercialLanding.astro';
import type { EcommerceLandingProps } from '@/types/landing/props';

const { content } = Astro.props as EcommerceLandingProps;
---

<CommercialLanding
    content={content}
    source="ecommerce"
    heroVideo={HeroVideo}
    heroPoster={HeroVideoPreview.src}
    heroImageAlt="Ecommerce storefront preview"
/>
