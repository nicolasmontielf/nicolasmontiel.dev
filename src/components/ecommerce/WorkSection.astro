---
import type { EcommerceLandingContent } from '@/data/ecommerce-landing';
import ServiceIcon from '@components/ecommerce/ServiceIcon.astro';
import { sectionContainerClass, sectionLabelClass } from '@components/ecommerce/styles';

type Props = {
	work: EcommerceLandingContent['work'];
};

const { work } = Astro.props as Props;
---

<section id="work" class="border-y border-slate-200 bg-slate-50 py-16 md:py-20">
	<div class={sectionContainerClass}>
		<div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-start">
			<div class="grid gap-5 md:grid-cols-2">
				{
					work.cards.map((item) => (
						<article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]">
                            <div class="flex items-center gap-x-3">
							    <ServiceIcon name={item.icon} />
							    <h3 class="flex-1 text-lg font-semibold tracking-tight text-slate-900">
                                    {item.title}
                                </h3>
                            </div>
							<p class="mt-3 text-sm leading-relaxed text-slate-600">{item.description}</p>
						</article>
					))
				}
			</div>

			<div>
				<p class={sectionLabelClass}>{work.eyebrow}</p>
				<h2 class="mt-4 text-2xl font-bold tracking-tight text-slate-950 md:text-4xl">{work.title}</h2>
				<p class="mt-5 text-base leading-relaxed text-slate-600">{work.subtitle}</p>

				<div class="mt-8 h-px bg-slate-200"></div>

				<p class="mt-8 text-sm font-semibold tracking-tight text-slate-950">{work.noteTitle}</p>
				<p class="mt-3 text-sm leading-relaxed text-slate-600">{work.noteDescription}</p>
			</div>
		</div>
	</div>
</section>
