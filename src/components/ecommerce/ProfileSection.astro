---
import type { EcommerceLandingContent } from '@/data/ecommerce-landing';
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import { sectionContainerClass } from '@components/ecommerce/styles';

type Props = {
	profile: EcommerceLandingContent['profile'];
	aboutLink: string;
};

const { profile, aboutLink } = Astro.props as Props;
---

<SharedProfileSection profile={profile} aboutLink={aboutLink} containerClass={sectionContainerClass} sectionId="profile" />
