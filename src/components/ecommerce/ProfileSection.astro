---
import SharedProfileSection from '@components/common/landing/ProfileSection.astro';
import type { EcommerceProfileSectionProps } from '@/types/landing/props';
import { sectionContainerClass } from '@components/ecommerce/styles';
const { profile, aboutLink } = Astro.props as EcommerceProfileSectionProps;
---

<SharedProfileSection
    profile={profile}
    aboutLink={aboutLink}
    containerClass={sectionContainerClass}
    sectionId="profile"
/>
