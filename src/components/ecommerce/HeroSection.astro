---
import type { EcommerceHeroSectionProps } from '@/types/landing/props';
import {
    sectionContainerClass,
    sectionLabelClass,
} from '@components/ecommerce/styles';
import heroImage from '@assets/storefront-preview.png';

const { hero, links } = Astro.props as EcommerceHeroSectionProps;
---

<section
    id="hero"
    class="bg-white py-14 md:py-20"
>
    <div
        class={`${sectionContainerClass} grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(360px,460px)] lg:items-center`}
    >
        <div>
            <p class={sectionLabelClass}>{hero.badge}</p>
            <h1
                class="mt-6 max-w-2xl text-4xl font-bold tracking-tight text-slate-950 md:text-6xl md:leading-[1.02]"
            >
                {hero.title}
            </h1>
            <p
                class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 md:text-lg"
            >
                {hero.description}
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
                <a
                    href={links.whatsapp}
                    target="_blank"
                    rel="noreferrer"
                    class="rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700"
                >
                    {hero.primaryCtaLabel}
                </a>
                <a
                    href={links.about}
                    class="rounded-md border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900"
                >
                    {hero.secondaryCtaLabel}
                </a>
            </div>

            <p class="mt-6 max-w-xl text-sm leading-relaxed text-slate-500">
                {hero.trustNote}
            </p>
        </div>

        <div class="relative">
            <img
                src={heroImage.src}
                alt="Preview visual de una storefront ecommerce"
                class="max-h-[45rem]"
            />

            <div
                class="absolute -bottom-5 left-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-[0_16px_40px_-30px_rgba(15,23,42,0.4)]"
            >
                <p
                    class="text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400"
                >
                    {hero.floatingCardLabel}
                </p>
                <p class="mt-1 text-sm font-medium text-slate-900">
                    {hero.floatingCardValue}
                </p>
            </div>
        </div>
    </div>
</section>
