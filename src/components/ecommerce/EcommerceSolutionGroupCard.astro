---
type Props = {
    title: string;
    subtitle: string;
    items: string[];
};

const { title, subtitle, items } = Astro.props as Props;
---

<article class="rounded-[1.4rem] border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.18)]">
    <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-indigo-600">
        {title}
    </p>
    <p class="mt-3 text-sm leading-relaxed text-slate-600">
        {subtitle}
    </p>
    <ul class="mt-5 grid gap-3">
        {items.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700">
                <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-indigo-500" />
                <span>{item}</span>
            </li>
        ))}
    </ul>
</article>
