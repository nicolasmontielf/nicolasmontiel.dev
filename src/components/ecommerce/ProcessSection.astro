---
import { DEFAULT_LOCALE } from '@/i18n/locales';
import type { EcommerceProcessSectionProps } from '@/types/landing/props';
import {
    sectionContainerClass,
    sectionLabelClass,
} from '@components/ecommerce/styles';

const { process } = Astro.props as EcommerceProcessSectionProps;
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const stepLabel = locale === 'es' ? 'Paso' : 'Step';
---

<section
    id="process"
    class="border-y border-slate-200 bg-[linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] py-16 md:py-20"
>
    <div class={sectionContainerClass}>
        <div class="max-w-2xl">
            <p class={sectionLabelClass}>{process.eyebrow}</p>
            <h2
                class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl"
            >
                {process.title}
            </h2>
            <p class="mt-4 text-base leading-relaxed text-slate-600">
                {process.description}
            </p>
        </div>

        <ol class="relative mt-12 grid gap-5 md:grid-cols-2">
            <div
                class="pointer-events-none absolute left-6 top-6 hidden h-[calc(100%-3rem)] w-px bg-gradient-to-b from-indigo-200 via-indigo-100 to-transparent md:block"
            >
            </div>
            {
                process.steps.map((step, index) => (
                    <li
                        class:list={[
                            'relative rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-[0_20px_45px_-34px_rgba(15,23,42,0.18)]',
                            index % 2 === 1 && 'md:translate-y-10',
                        ]}
                    >
                        <div class="flex items-start gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-indigo-600 text-sm font-semibold text-white shadow-[0_12px_30px_-18px_rgba(79,70,229,0.9)]">
                                {index + 1}
                            </div>
                            <div>
                                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">
                                    {stepLabel} {index + 1}
                                </p>
                                <h3 class="mt-2 text-xl font-semibold tracking-tight text-slate-950">
                                    {step.title}
                                </h3>
                                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                    {step.description}
                                </p>
                            </div>
                        </div>
                    </li>
                ))
            }
        </ol>
    </div>
</section>
