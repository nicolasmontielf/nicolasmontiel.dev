---
import avatar from '@/assets/nicolas-montiel-avatar.png';
import LandingButtonLink from '@components/common/landing/LandingButtonLink.astro';
import {
    landingContainerClass,
    landingLabelClass,
} from '@components/common/landing/styles';
import { getHomePath } from '@/i18n/routing';
import logo from '@assets/logo.png';
import type { CommercialProfileContent } from '@/types/commercial-profile';

type Props = {
    content: CommercialProfileContent;
};

const { content } = Astro.props as Props;
---

<div class="min-h-screen bg-[linear-gradient(180deg,#f8fafc_0%,#ffffff_18%,#f8fafc_100%)] text-slate-700">
    <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class={`flex items-center justify-between gap-5 py-4 ${landingContainerClass}`}>
            <a
                href={getHomePath(content.locale)}
                class="group flex items-center gap-3 text-slate-950"
            >
                <img
                    src={logo.src}
                    alt="Nicolás Montiel"
                    class="h-10 w-auto"
                    width={logo.width}
                    height={logo.height}
                />
                <span class="leading-none">
                    <span class="block text-sm font-bold tracking-tight">
                        Nicolas Montiel
                    </span>
                    <span class="mt-1 block text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400">
                        {content.navbar.label}
                    </span>
                </span>
            </a>

            <nav class="hidden items-center gap-5 text-sm text-slate-500 xl:flex">
                {
                    content.navbar.items.map((item) => (
                        <a
                            href={`#${item.id}`}
                            class="transition-colors hover:text-slate-950"
                        >
                            {item.label}
                        </a>
                    ))
                }
            </nav>

            <div class="hidden items-center gap-3 lg:flex">
                <LandingButtonLink
                    href={content.navbar.primaryCtaHref}
                    variant="secondary"
                    className="px-4 py-2 text-xs"
                >
                    {content.navbar.primaryCtaLabel}
                </LandingButtonLink>
                <LandingButtonLink
                    href={content.navbar.secondaryCtaHref}
                    variant="primary"
                    className="px-4 py-2 text-xs"
                >
                    {content.navbar.secondaryCtaLabel}
                </LandingButtonLink>
            </div>
        </div>
    </header>

    <main class="pb-20">
        <section
            id="profile"
            class="border-t border-indigo-100 bg-[linear-gradient(180deg,#eef2ff_0%,#f8fbff_100%)] px-4 pb-20 pt-12 sm:px-6 lg:px-8 lg:pt-16"
        >
            <div class={landingContainerClass}>
                <div class="py-2 md:py-4">
                    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_240px] lg:items-start xl:grid-cols-[minmax(0,1fr)_280px]">
                        <div class="max-w-3xl">
                            <h1 class="text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">
                                {content.profile.title}
                            </h1>
                            <div class="mt-6 space-y-4 text-base leading-relaxed text-slate-600">
                                {content.profile.paragraphs.map((paragraph) => (
                                    <p>{paragraph}</p>
                                ))}
                            </div>
                        </div>

                        <div class="flex justify-start lg:justify-end">
                            <div class="w-[170px] overflow-hidden rounded-[1.8rem] border border-white/70 bg-white/60 p-2 shadow-[0_18px_45px_-38px_rgba(15,23,42,0.18)] backdrop-blur sm:w-[190px] xl:w-[220px]">
                                <img
                                    src={avatar.src}
                                    alt={content.profile.avatarAlt}
                                    width={avatar.width}
                                    height={avatar.height}
                                    class="h-auto w-full rounded-[1.2rem] object-cover"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="mt-10 grid gap-px overflow-hidden rounded-[1.35rem] border border-slate-200 bg-slate-200 md:grid-cols-2 xl:grid-cols-4">
                        {content.profile.stats.map((item) => (
                            <div class="bg-white p-5">
                                <p class="text-3xl font-bold tracking-tight text-slate-950">
                                    {item.value}
                                </p>
                                <p class="mt-2 text-sm font-medium text-slate-700">
                                    {item.label}
                                </p>
                                <p class="mt-2 text-sm leading-relaxed text-slate-600">
                                    {item.description}
                                </p>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <section id="why-work" class="px-4 pt-20 sm:px-6 lg:px-8">
            <div class={landingContainerClass}>
                <div class="max-w-2xl">
                    <p class={landingLabelClass}>{content.reasons.eyebrow}</p>
                    <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">
                        {content.reasons.title}
                    </h2>
                    <p class="mt-4 text-base leading-relaxed text-slate-600">
                        {content.reasons.description}
                    </p>
                </div>

                <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
                    {content.reasons.items.map((item, index) => (
                        <article class="rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-[0_18px_45px_-34px_rgba(15,23,42,0.18)]">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-indigo-600">
                                {(index + 1).toString().padStart(2, '0')}
                            </p>
                            <h3 class="mt-5 text-xl font-semibold tracking-tight text-slate-950">
                                {item.title}
                            </h3>
                            <p class="mt-3 text-sm leading-relaxed text-slate-600">
                                {item.description}
                            </p>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <section
            id="process"
            class="mt-20 border-t border-indigo-100 bg-[linear-gradient(180deg,#eef2ff_0%,#f8fbff_100%)] px-4 pb-20 pt-20 sm:px-6 lg:px-8"
        >
            <div class={landingContainerClass}>
                <div class="max-w-2xl">
                    <p class={landingLabelClass}>{content.process.eyebrow}</p>
                    <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">
                        {content.process.title}
                    </h2>
                    <p class="mt-4 text-base leading-relaxed text-slate-600">
                        {content.process.description}
                    </p>
                </div>

                <ol class="mt-12 divide-y divide-slate-200 overflow-hidden rounded-[1.6rem] border border-slate-200">
                    {content.process.steps.map((step) => (
                        <li class="grid gap-4 bg-white p-5 md:grid-cols-[140px_1fr] md:items-start">
                            <div>
                                <span class="inline-flex rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700">
                                    {step.label}
                                </span>
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold tracking-tight text-slate-950">
                                    {step.title}
                                </h3>
                                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-600">
                                    {step.description}
                                </p>
                            </div>
                        </li>
                    ))}
                </ol>
            </div>
        </section>

        <section
            id="contexts"
            class="border-t border-slate-200 px-4 pt-20 sm:px-6 lg:px-8"
        >
            <div class={landingContainerClass}>
                <div class="max-w-2xl">
                    <p class={landingLabelClass}>{content.contexts.eyebrow}</p>
                    <h2 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">
                        {content.contexts.title}
                    </h2>
                    <p class="mt-4 text-base leading-relaxed text-slate-600">
                        {content.contexts.description}
                    </p>
                </div>

                <div class="mt-12 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                    {content.contexts.items.map((item, index) => (
                        <div
                            class:list={[
                                'rounded-[1.25rem] border border-slate-200 bg-white px-5 py-4',
                                index === content.contexts.items.length - 1 &&
                                    'bg-[linear-gradient(180deg,#eef2ff_0%,#ffffff_100%)]',
                            ]}
                        >
                            <p class="text-sm font-semibold tracking-tight text-slate-950">
                                {item.title}
                            </p>
                            <p class="mt-2 text-xs leading-relaxed text-slate-600">
                                {item.description}
                            </p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section
            id="contact"
            class="mt-20 border-t border-indigo-100 bg-[linear-gradient(180deg,#eef2ff_0%,#f8fbff_100%)] px-4 pb-20 pt-20 sm:px-6 lg:px-8"
        >
            <div class={landingContainerClass}>
                <div class="rounded-[2rem] border border-slate-200 bg-white px-6 py-8 text-slate-950 shadow-[0_24px_70px_-48px_rgba(15,23,42,0.18)] md:px-8 md:py-10">
                    <div class="grid gap-8 lg:grid-cols-[1.1fr_auto] lg:items-center">
                        <div class="max-w-2xl">
                            <p class={landingLabelClass}>{content.contact.eyebrow}</p>
                            <h2 class="mt-4 text-3xl font-bold tracking-tight md:text-4xl">
                                {content.contact.title}
                            </h2>
                        </div>

                        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                            <a
                                href={content.contact.primaryHref}
                                class="rounded-full bg-slate-950 px-5 py-3 text-center text-sm font-semibold text-white transition hover:bg-slate-800"
                            >
                                {content.contact.primaryLabel}
                            </a>
                            <a
                                href={content.contact.secondaryHref}
                                target="_blank"
                                rel="noreferrer"
                                class="rounded-full border border-slate-300 px-5 py-3 text-center text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-white"
                            >
                                {content.contact.secondaryLabel}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>
