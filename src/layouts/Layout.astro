---
import Navbar from '@components/layout/Navbar.astro';
// @ts-ignore
import '@fontsource-variable/space-grotesk';
import { getMessages } from '@/i18n/messages';
import { DEFAULT_LOCALE } from '@/i18n/locales';
import type { LayoutProps } from '@/types/layout';
import {
	DEFAULT_OG_IMAGE,
	DEFAULT_ROBOTS,
	DEFAULT_THEME_COLOR,
	PERSON_ID,
	SAME_AS_LINKS,
	SITE_NAME,
	SITE_TITLE_SUFFIX,
	SITE_URL,
	WEBSITE_ID,
	getAlternateLanguageLinks,
	getLanguageTag,
	getOpenGraphLocale,
	getXDefaultHref,
	toAbsoluteUrl,
} from '@/seo/site';

const {
	locale: localeProp,
	title,
	description,
	canonical,
	ogImage = DEFAULT_OG_IMAGE,
	robots = DEFAULT_ROBOTS,
	structuredData,
	showDefaultNavbar = true,
	containerMode = 'constrained',
	includeAlternateLinks = true,
} = Astro.props as LayoutProps;

const locale = Astro.locals.locale ?? localeProp ?? DEFAULT_LOCALE;

const messages = getMessages(locale);
const pageDescription = description || messages.layout.defaultDescription;
const pageTitle = title ? `${title} | ${SITE_TITLE_SUFFIX}` : `${messages.layout.defaultTitle} | ${SITE_TITLE_SUFFIX}`;
const resolvedCanonical = canonical || toAbsoluteUrl(Astro.url.pathname);
const openGraphLocale = getOpenGraphLocale(locale);
const alternateLanguageLinks = includeAlternateLinks ? getAlternateLanguageLinks(Astro.url.pathname) : [];
const alternateOpenGraphLocales = alternateLanguageLinks
	.filter((link) => link.locale !== locale)
	.map((link) => getOpenGraphLocale(link.locale));
const webpageSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `${resolvedCanonical}#webpage`,
	url: resolvedCanonical,
	name: pageTitle,
	description: pageDescription,
	inLanguage: getLanguageTag(locale),
	isPartOf: {
		'@id': WEBSITE_ID,
	},
	about: {
		'@id': PERSON_ID,
	},
};
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': WEBSITE_ID,
	url: SITE_URL,
	name: SITE_NAME,
	inLanguage: ['en-US', 'es-PY'],
	publisher: {
		'@id': PERSON_ID,
	},
};
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': PERSON_ID,
	name: SITE_NAME,
	url: SITE_URL,
	jobTitle: locale === 'es' ? 'Ingeniero de software full-stack' : 'Full-stack software engineer',
	description: messages.layout.defaultDescription,
	email: 'mailto:nicolasmontielf@gmail.com',
	sameAs: SAME_AS_LINKS,
	knowsAbout: [
		'PHP',
		'Laravel',
		'Node.js',
		'React',
		'Vue.js',
		'TypeScript',
		'SQL',
		'NoSQL',
		'Ecommerce',
		'AI-assisted software engineering',
	],
};
const additionalStructuredData = structuredData
	? (Array.isArray(structuredData) ? structuredData : [structuredData])
	: [];
const structuredDataEntries = [personSchema, websiteSchema, webpageSchema, ...additionalStructuredData];
const bodyClass =
	containerMode === 'fluid'
		? 'bg-slate-50 text-slate-600 mb-40 selection:bg-indigo-100 selection:text-indigo-900'
		: 'max-w-screen-lg lg:px-0 px-3 mx-auto bg-slate-50 text-slate-600 mb-40 selection:bg-indigo-100 selection:text-indigo-900';

const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
	<head>
        {
            !isDev && (
                <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
                })(window,document,'script','dataLayer','GTM-WGW97W5L');</script>
            )
        }

		<meta charset="UTF-8" />

        <meta name="description" content={pageDescription} />
		<meta name="author" content={SITE_NAME} />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={DEFAULT_THEME_COLOR} />
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<!-- Open Graph meta tags -->
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={openGraphLocale} />
		{alternateOpenGraphLocales.map((value) => <meta property="og:locale:alternate" content={value} />)}
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={pageTitle} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta property="og:site_name" content={SITE_NAME} />

		<!-- Twitter meta tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={pageTitle} />
		<meta name="twitter:url" content={resolvedCanonical} />
		<meta name="twitter:site" content="@nicolasmontielf" />

		<link rel="canonical" href={resolvedCanonical} />
		{alternateLanguageLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
		<link rel="alternate" hreflang="x-default" href={getXDefaultHref(Astro.url.pathname)} />
		<slot name="head" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{
			structuredDataEntries.map((entry) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
			))
		}
		<title>{pageTitle}</title>
	</head>

	<body class={bodyClass}>
        {!isDev && (
            <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WGW97W5L"
            height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        )}

		{
			showDefaultNavbar && (
				<div class="lg:mb-5">
					<Navbar />
				</div>
			)
		}

        <main>
            <slot />
        </main>

	</body>
</html>
