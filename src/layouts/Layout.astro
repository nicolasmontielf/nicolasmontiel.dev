---
import Navbar from '@components/layout/Navbar.astro';
import '@fontsource-variable/space-grotesk';
import { getMessages } from '@/i18n/messages';
import type { Locale } from '@/i18n/locales';
import {
	DEFAULT_OG_IMAGE,
	DEFAULT_ROBOTS,
	DEFAULT_THEME_COLOR,
	PERSON_ID,
	SAME_AS_LINKS,
	SITE_NAME,
	SITE_TITLE_SUFFIX,
	SITE_URL,
	WEBSITE_ID,
	getAlternateLanguageLinks,
	getLanguageTag,
	getOpenGraphLocale,
	getXDefaultHref,
	toAbsoluteUrl,
} from '@/seo/site';

type Props = {
	locale: Locale;
	title?: string;
	description?: string;
	canonical?: string;
	ogImage?: string;
	robots?: string;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	showDefaultNavbar?: boolean;
	containerMode?: 'constrained' | 'fluid';
};

const {
	locale,
	title,
	description,
	canonical,
	ogImage = DEFAULT_OG_IMAGE,
	robots = DEFAULT_ROBOTS,
	structuredData,
	showDefaultNavbar = true,
	containerMode = 'constrained',
} = Astro.props as Props;

const messages = getMessages(locale);
const pageDescription = description || messages.layout.defaultDescription;
const pageTitle = title ? `${title} | ${SITE_TITLE_SUFFIX}` : `${messages.layout.defaultTitle} | ${SITE_TITLE_SUFFIX}`;
const resolvedCanonical = canonical || toAbsoluteUrl(Astro.url.pathname);
const openGraphLocale = getOpenGraphLocale(locale);
const alternateLanguageLinks = getAlternateLanguageLinks(Astro.url.pathname);
const alternateOpenGraphLocales = alternateLanguageLinks
	.filter((link) => link.locale !== locale)
	.map((link) => getOpenGraphLocale(link.locale));
const webpageSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `${resolvedCanonical}#webpage`,
	url: resolvedCanonical,
	name: pageTitle,
	description: pageDescription,
	inLanguage: getLanguageTag(locale),
	isPartOf: {
		'@id': WEBSITE_ID,
	},
	about: {
		'@id': PERSON_ID,
	},
};
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': WEBSITE_ID,
	url: SITE_URL,
	name: SITE_NAME,
	inLanguage: ['en-US', 'es-PY'],
	publisher: {
		'@id': PERSON_ID,
	},
};
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': PERSON_ID,
	name: SITE_NAME,
	url: SITE_URL,
	jobTitle: locale === 'es' ? 'Ingeniero de software full-stack' : 'Full-stack software engineer',
	description: messages.layout.defaultDescription,
	email: 'mailto:nicolasmontielf@gmail.com',
	sameAs: SAME_AS_LINKS,
	knowsAbout: [
		'PHP',
		'Laravel',
		'Node.js',
		'React',
		'Vue.js',
		'TypeScript',
		'SQL',
		'NoSQL',
		'Ecommerce',
		'AI-assisted software engineering',
	],
};
const additionalStructuredData = structuredData
	? (Array.isArray(structuredData) ? structuredData : [structuredData])
	: [];
const structuredDataEntries = [personSchema, websiteSchema, webpageSchema, ...additionalStructuredData];
const bodyClass =
	containerMode === 'fluid'
		? 'bg-slate-50 text-slate-600 mb-40 selection:bg-indigo-100 selection:text-indigo-900'
		: 'max-w-screen-lg lg:px-0 px-3 mx-auto bg-slate-50 text-slate-600 mb-40 selection:bg-indigo-100 selection:text-indigo-900';
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
		<head>
		{!import.meta.env.DEV && (
			<>
				<!-- Google tag (gtag.js) -->
                <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FS54TMLFTL"></script>
				<script is:inline>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());

					gtag('config', 'G-FS54TMLFTL');
				</script>
                
                <meta name="facebook-domain-verification" content="172u9yzx9b8ek0kxggntkrdb6brncu" />

                <!-- Meta Pixel Code -->
                <script is:inline>
                !function(f,b,e,v,n,t,s)
                {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
                n.callMethod.apply(n,arguments):n.queue.push(arguments)};
                if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
                n.queue=[];t=b.createElement(e);t.async=!0;
                t.src=v;s=b.getElementsByTagName(e)[0];
                s.parentNode.insertBefore(t,s)}(window, document,'script',
                'https://connect.facebook.net/en_US/fbevents.js');
                fbq('init', '1323472016359962');
                fbq('track', 'PageView');
                </script>
                <noscript><img height="1" width="1" style="display:none"
                src="https://www.facebook.com/tr?id=1323472016359962&ev=PageView&noscript=1"
                /></noscript>
                <!-- End Meta Pixel Code -->
			</>
		)}
		<meta charset="UTF-8" />
		<meta name="description" content={pageDescription} />
		<meta name="author" content={SITE_NAME} />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={DEFAULT_THEME_COLOR} />
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<!-- Open Graph meta tags -->
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={openGraphLocale} />
		{alternateOpenGraphLocales.map((value) => <meta property="og:locale:alternate" content={value} />)}
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={pageTitle} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta property="og:site_name" content={SITE_NAME} />

		<!-- Twitter meta tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={pageTitle} />
		<meta name="twitter:url" content={resolvedCanonical} />
		<meta name="twitter:site" content="@nicolasmontielf" />

		<link rel="canonical" href={resolvedCanonical} />
		{alternateLanguageLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
		<link rel="alternate" hreflang="x-default" href={getXDefaultHref(Astro.url.pathname)} />
		<slot name="head" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{
			structuredDataEntries.map((entry) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
			))
		}
		<title>{pageTitle}</title>
	</head>

	<body class={bodyClass}>
		{
			showDefaultNavbar && (
				<div class="lg:mb-5">
					<Navbar locale={locale} currentPath={Astro.url.pathname} labels={messages.navbar} />
				</div>
			)
		}

        <main>
            <slot />
        </main>

	</body>
</html>
