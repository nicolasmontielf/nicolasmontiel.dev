---
import CommercialProfilePage from '@components/commercial-profile/Page.astro';
import { getCommercialProfileContent } from '@/data/work-with-me';
import { getCommercialProfilePath } from '@/i18n/routing';
import { isLocale } from '@/i18n/locales';
import { PERSON_ID, SITE_URL } from '@/seo/site';
import Layout from '@/layouts/Layout.astro';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
    return Astro.redirect('/en');
}

if (lang === 'es') {
    return Astro.redirect(getCommercialProfilePath('es'));
}

const content = getCommercialProfileContent(lang);
const canonical = `${SITE_URL}${getCommercialProfilePath(lang)}`;
const structuredData = {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    '@id': `${canonical}#service`,
    name: 'Why work with me',
    url: canonical,
    description: content.meta.description,
    provider: {
        '@id': PERSON_ID,
    },
};
---

<Layout
    title={content.meta.title}
    description={content.meta.description}
    canonical={canonical}
    structuredData={structuredData}
    showDefaultNavbar={false}
    containerMode="fluid"
>
    <CommercialProfilePage content={content} />
</Layout>
