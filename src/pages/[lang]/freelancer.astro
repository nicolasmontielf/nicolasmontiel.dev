---
import { ChevronUp } from '@lucide/astro';
import FreelancerAbout from '@/components/freelancer/FreelancerAbout.astro';
import FreelancerCaseStudies from '@/components/freelancer/FreelancerCaseStudies.astro';
import FreelancerContact from '@/components/freelancer/FreelancerContact.astro';
import FreelancerNavbar from '@/components/freelancer/FreelancerNavbar.astro';
import FreelancerProcess from '@/components/freelancer/FreelancerProcess.astro';
import FreelancerServices from '@/components/freelancer/FreelancerServices.astro';
import FreelancerTestimonials from '@/components/freelancer/FreelancerTestimonials.astro';
import { DEFAULT_LOCALE, isLocale } from '@/i18n/locales';
import Layout from '@/layouts/Layout.astro';
import { SITE_URL } from '@/seo/site';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
    return Astro.redirect('/en');
}

const locale = Astro.locals.locale ?? lang ?? DEFAULT_LOCALE;
const canonical = `${SITE_URL}/${locale}/freelancer`;
---

<Layout
    title="Freelancer"
    description="Freelancer landing page inspired by a dark portfolio reference."
    canonical={canonical}
    showDefaultNavbar={false}
    containerMode="fluid"
>
    <div
        id="top"
        class="min-h-screen bg-background-primary font-sans text-white"
    >
        <FreelancerNavbar locale={locale} />

        <main>
            <FreelancerAbout />
            <FreelancerServices />
            <FreelancerProcess />
            <FreelancerCaseStudies />
            <FreelancerTestimonials />
            <!-- <FreelancerFaq /> -->
            <FreelancerContact />
        </main>

        <footer class="border-t border-[#101827] bg-[#060b18] px-6 py-10 md:px-10">
            <div class="mx-auto max-w-[1040px] text-center">
                <p class="text-[18px] font-bold text-white">Alex Rivera</p>
                <p class="mx-auto mt-2 max-w-[260px] text-[13px] leading-6 text-[#8da0bd]">
                    Full-stack developer and designer crafting exceptional
                    digital experiences.
                </p>

                <div class="mt-5 flex items-center justify-center gap-3">
                    <a
                        href="#"
                        aria-label="GitHub"
                        class="flex h-7 w-7 items-center justify-center rounded-[6px] bg-[#2b3548] text-[11px] font-semibold text-[#dbe4f5]"
                    >
                        G
                    </a>
                    <a
                        href="#"
                        aria-label="X"
                        class="flex h-7 w-7 items-center justify-center rounded-[6px] bg-[#2b3548] text-[11px] font-semibold text-[#dbe4f5]"
                    >
                        X
                    </a>
                    <a
                        href="#"
                        aria-label="LinkedIn"
                        class="flex h-7 w-7 items-center justify-center rounded-[6px] bg-[#2b3548] text-[11px] font-semibold text-[#dbe4f5]"
                    >
                        in
                    </a>
                    <a
                        href="#"
                        aria-label="Dribbble"
                        class="flex h-7 w-7 items-center justify-center rounded-[6px] bg-[#2b3548] text-[11px] font-semibold text-[#dbe4f5]"
                    >
                        o
                    </a>
                </div>

                <div class="mt-5 flex flex-wrap items-center justify-center gap-4 text-[12px] text-[#7f90aa]">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Style Guide</a>
                </div>

                <p class="mt-5 text-[12px] text-[#7f90aa]">
                    &copy; 2026 Alex Rivera. All rights reserved.
                </p>
            </div>
        </footer>

        <a
            href="#top"
            aria-label="Back to top"
            class="fixed bottom-4 right-4 flex h-9 w-9 items-center justify-center rounded-full bg-[#4e5463] text-white shadow-[0_10px_30px_rgba(0,0,0,0.35)]"
        >
            <ChevronUp class="h-4 w-4" />
        </a>
    </div>
</Layout>
