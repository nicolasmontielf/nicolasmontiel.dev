---
import Layout from '@/layouts/Layout.astro';
import Landing from '@components/ecommerce/Landing.astro';
import { getEcommerceLandingContent } from '@/data/ecommerce-landing';
import { DEFAULT_LOCALE, isLocale } from '@/i18n/locales';
import { PERSON_ID } from '@/seo/site';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
	return Astro.redirect(`/${DEFAULT_LOCALE}`);
}

const content = getEcommerceLandingContent(lang);
const canonical = `https://www.nicolasmontiel.dev/${lang}/ecommerce`;
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	'@id': `${canonical}#service`,
	name:
		lang === 'es'
			? 'Servicios freelance de ecommerce a medida de Nicolás Montiel'
			: 'Nicolás Montiel freelance custom ecommerce services',
	url: canonical,
	description: content.meta.description,
	serviceType:
		lang === 'es'
			? [
					'Ecommerce a medida',
					'Diseño de storefront ecommerce',
					'Implementación ecommerce',
					'Google Analytics y Search Console',
					'SEO técnico básico',
					'Soporte e integraciones',
				]
			: [
					'Custom ecommerce',
					'Ecommerce storefront design',
					'Ecommerce implementation',
					'Google Analytics and Search Console',
					'Basic technical SEO',
					'Support and integrations',
				],
	areaServed: ['Paraguay', 'Latin America', 'United States', 'Europe'],
	availableLanguage: lang === 'es' ? ['es'] : ['en'],
	provider: {
		'@id': PERSON_ID,
	},
};
---

<Layout
	locale={lang}
	title={content.meta.title}
	description={content.meta.description}
	canonical={canonical}
	structuredData={structuredData}
	showDefaultNavbar={false}
	containerMode="fluid"
>
	<Landing locale={lang} content={content} />
</Layout>
