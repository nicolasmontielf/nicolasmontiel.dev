---
import { getHomeContent } from '@/data/home-content';
import Layout from '@/layouts/Layout.astro';
import Presentation from '@components/home/Presentation.astro';
import WorkExperience from '@components/home/WorkExperience.astro';
import Certifications from '@components/home/Certifications.astro';
import { getMessages } from '@/i18n/messages';
import { DEFAULT_LOCALE, isLocale } from '@/i18n/locales';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
    return Astro.redirect(`/${DEFAULT_LOCALE}`);
}

const messages = getMessages(lang);
const homeContent = getHomeContent(lang);
---

<Layout
    title={messages.homePage.title}
    description={messages.homePage.description}
>
    <section id="presentation-section">
        <Presentation
            variant="pro"
            greeting={homeContent.presentation.greeting}
        />
    </section>

    <section id="experience">
        <WorkExperience />
    </section>

    <section id="certifications">
        <Certifications />
    </section>
</Layout>
