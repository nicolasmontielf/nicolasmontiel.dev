---
import Layout from '@/layouts/Layout.astro';
import { getWebLandingContent } from '@/data/web-landing';
import { isLocale } from '@/i18n/locales';
import { PERSON_ID } from '@/seo/site';
import Landing from '@components/web/Landing.astro';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
	return Astro.redirect('/en');
}

const content = getWebLandingContent(lang);
const canonical = `https://www.nicolasmontiel.dev/${lang}/web`;
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	'@id': `${canonical}#service`,
	name:
		lang === 'es'
			? 'Servicios freelance de desarrollo web a medida de Nicolas Montiel'
			: 'Nicolas Montiel freelance custom website and webapp services',
	url: canonical,
	description: content.meta.description,
	serviceType:
		lang === 'es'
			? [
					'Landing pages a medida',
					'Webs institucionales',
					'Galerias y portfolios web',
					'Sitios administrables y CMS',
					'Webapps con panel administrativo',
					'Desarrollo full-stack e integraciones',
				]
			: [
					'Custom landing pages',
					'Institutional websites',
					'Web galleries and portfolios',
					'Content-managed websites and CMS',
					'Webapps with admin panels',
					'Full-stack development and integrations',
				],
	provider: {
		'@id': PERSON_ID,
	},
};
---

<Layout
	locale={lang}
	title={content.meta.title}
	description={content.meta.description}
	canonical={canonical}
	structuredData={structuredData}
	showDefaultNavbar={false}
	containerMode="fluid"
>
	<Landing locale={lang} content={content} />
</Layout>
