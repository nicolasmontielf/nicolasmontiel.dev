---
import RecruiterProfilePage from '@components/home/RecruiterProfilePage.astro';
import { getWhyHireMeSeo } from '@/data/why-hire-me';
import { isLocale } from '@/i18n/locales';
import { getRecruiterProfilePath } from '@/i18n/routing';
import Layout from '@/layouts/Layout.astro';
import { SITE_URL } from '@/seo/site';

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
    return Astro.redirect('/en');
}

if (lang === 'en') {
    return Astro.redirect(getRecruiterProfilePath('en'));
}

const seo = getWhyHireMeSeo(lang);
const canonical = `${SITE_URL}${getRecruiterProfilePath(lang)}`;
---

<Layout
    title={seo.title}
    description={seo.description}
    canonical={canonical}
>
    <RecruiterProfilePage />
</Layout>
